# Neon Postgres connection string. Required for every route.
DATABASE_URL=

# Clerk — server-side JWT verification. Get from Clerk dashboard → API keys.
CLERK_SECRET_KEY=

# Comma-separated emails treated as admins when a Clerk user doesn't have
# `publicMetadata.role === "admin"`. Used as a fallback.
FEEDBACK_ADMIN_EMAILS=

# Resend transactional email (free tier: 100/day). https://resend.com/
RESEND_API_KEY=
EMAIL_FROM="Pulse HR <onboarding@resend.dev>"

# Absolute URL of the Vite SPA (where release-email CTAs land). No trailing slash.
# Dev: http://localhost:5173 · Prod: https://app.pulsehr.it
APP_BASE_URL=http://localhost:5173

# Bearer token required by /cron/* in addition to Vercel/Render/GitHub headers.
CRON_SECRET=

# Cloudflare R2 — S3-compatible blob storage for screenshots.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pulse-screenshots
# Public base URL for r2.dev or a custom subdomain. No trailing slash.
R2_PUBLIC_BASE_URL=

# Comma-separated list of origins the browser is allowed to call this API from.
# Supports literal origins and `*.vercel.app` style globs.
# Dev:  http://localhost:5173
# Prod: https://app.pulsehr.it,https://pulsehr.it,https://*.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Render injects PORT; default 3000 locally.
PORT=3000
