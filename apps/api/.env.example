# Neon Postgres connection string. Required for every route.
DATABASE_URL=

# Clerk — both keys come from the Clerk dashboard → API Keys.
# The secret key verifies JWTs server-side; the publishable key is used by
# @clerk/backend to pick the right instance when fetching user profiles.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Comma-separated emails treated as admins when a Clerk user doesn't have
# `publicMetadata.role === "admin"`. Used as a fallback.
FEEDBACK_ADMIN_EMAILS=

# Resend transactional email (free tier: 100/day). https://resend.com/
RESEND_API_KEY=
EMAIL_FROM="Pulse HR <onboarding@resend.dev>"

# Absolute URL of the Vite SPA (where release-email CTAs land). No trailing slash.
# Dev: http://localhost:5173 · Prod: https://app.pulsehr.it
APP_BASE_URL=http://localhost:5173

# Bearer token required by /cron/* — GitHub Actions workflows send this.
# Generate with `openssl rand -base64 32`.
CRON_SECRET=

# Cloudflare R2 — S3-compatible blob storage for screenshots.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pulse-screenshots
# Public base URL for r2.dev or a custom subdomain. No trailing slash.
R2_PUBLIC_BASE_URL=

# Browser origins allowed to call this API. Comma-separated literal origins
# (`https://app.pulsehr.it`) or single-`*` globs (`https://*.vercel.app`).
# In dev (NODE_ENV !== "production") any `http://localhost:*` / `127.0.0.1:*`
# is always allowed, so you normally leave this blank locally.
# Prod: https://app.pulsehr.it,https://*.vercel.app
CORS_ALLOWED_ORIGINS=

# Render injects PORT; default 3000 locally.
PORT=3000
