{
  "name": "pulse-hr-marketing",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "pulsehr.it — Astro static site plus the studio content workspace (Remotion compositions and testreel browser recordings) that renders into apps/marketing/public/studio/*.",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4321",
    "astro": "astro",
    "studio": "remotion studio studio/remotion/index.ts",
    "render": "remotion render studio/remotion/index.ts DayInPulse public/studio/reel.mp4 --codec=h264 --crf=20",
    "render:webm": "remotion render studio/remotion/index.ts DayInPulse public/studio/reel.webm --codec=vp8",
    "render:poster": "remotion still studio/remotion/index.ts DayInPulse public/studio/poster.jpg --frame=0 --image-format=jpeg --jpeg-quality=88",
    "render:all": "bun run render && bun run render:webm && bun run render:poster",
    "reel": "bun studio/scripts/render-reel.ts",
    "reel:all": "bun studio/scripts/render-reel.ts --all",
    "reel:montage": "bun studio/scripts/render-reel.ts montage",
    "record": "bun studio/recordings/scripts/run.ts",
    "record:setup": "playwright install chromium --with-deps || playwright install chromium",
    "record:kudos-give": "bun studio/recordings/scripts/run.ts kudos-give",
    "record:workspace-create": "CRED=new bun studio/recordings/scripts/run.ts workspace-create",
    "record:time-attendance": "bun studio/recordings/scripts/run.ts time-attendance-entry",
    "record:growth-checks": "bun studio/recordings/scripts/run.ts growth-checks",
    "record:growth-tour": "bun studio/recordings/scripts/run.ts growth-tour",
    "record:skills-tour": "bun studio/recordings/scripts/run.ts skills-tour",
    "record:comment-create": "bun studio/recordings/scripts/run.ts comment-create",
    "record:comments-thread": "bun studio/recordings/scripts/run.ts comments-thread",
    "record:comments-thread-board": "bun studio/recordings/scripts/run.ts comments-thread-board",
    "record:comment-create-board": "bun studio/recordings/scripts/run.ts comment-create-board",
    "record:comments-loop": "bun studio/recordings/scripts/run.ts comments-loop",
    "record:feedback-live": "GHOSTS=1 bun studio/recordings/scripts/run.ts feedback-live",
    "record:trailer:dashboard": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts trailer-dashboard",
    "record:trailer:kudos": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts trailer-growth-kudos",
    "record:trailer:achievements": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts trailer-growth-achievements",
    "record:trailer:reports": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts trailer-reports",
    "record:trailer:all": "bun run record:trailer:dashboard && bun run record:trailer:kudos && bun run record:trailer:achievements && bun run record:trailer:reports",
    "record:trailer:shorts:dashboard": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts trailer-dashboard",
    "record:trailer:shorts:kudos": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts trailer-growth-kudos",
    "record:trailer:shorts:achievements": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts trailer-growth-achievements",
    "record:trailer:shorts:reports": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts trailer-reports",
    "record:trailer:shorts:all": "bun run record:trailer:shorts:dashboard && bun run record:trailer:shorts:kudos && bun run record:trailer:shorts:achievements && bun run record:trailer:shorts:reports",
    "trailer:shorts": "remotion render studio/remotion/index.ts trailer-shorts-v2 public/studio/trailer-shorts-v2.mp4 --codec=h264 --crf=18",
    "trailer:shorts:poster": "remotion still studio/remotion/index.ts trailer-shorts-v2 public/studio/trailer-shorts-v2-poster.jpg --frame=234 --image-format=jpeg --jpeg-quality=92",
    "detect-music": "bun studio/scripts/detect-music.ts",
    "record:aura:shorts:constellation": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts aura-constellation",
    "record:aura:shorts:skills": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts aura-skills-tour",
    "record:aura:shorts:saturation": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts aura-saturation",
    "record:aura:shorts:all": "bun run record:aura:shorts:constellation && bun run record:aura:shorts:skills && bun run record:aura:shorts:saturation",
    "record:aura:landscape:constellation": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts aura-constellation",
    "record:aura:landscape:skills": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts aura-skills-tour",
    "record:aura:landscape:saturation": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts aura-saturation",
    "record:aura:landscape:all": "bun run record:aura:landscape:constellation && bun run record:aura:landscape:skills && bun run record:aura:landscape:saturation",
    "record:aura:all": "bun run record:aura:shorts:all && bun run record:aura:landscape:all",
    "aura:shorts": "remotion render studio/remotion/index.ts aura-shorts-v1 public/studio/reels/aura-shorts.mp4 --codec=h264 --crf=18",
    "aura:shorts:poster": "remotion still studio/remotion/index.ts aura-shorts-v1 public/studio/reels/aura-shorts-poster.jpg --frame=60 --image-format=jpeg --jpeg-quality=92",
    "aura:landscape": "remotion render studio/remotion/index.ts aura-landscape-v1 public/studio/reels/aura-landscape.mp4 --codec=h264 --crf=18",
    "aura:landscape:poster": "remotion still studio/remotion/index.ts aura-landscape-v1 public/studio/reels/aura-landscape-poster.jpg --frame=60 --image-format=jpeg --jpeg-quality=92",
    "aura:all": "bun run aura:shorts && bun run aura:shorts:poster && bun run aura:landscape && bun run aura:landscape:poster",
    "record:teaser:dashboard": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts teaser-dashboard",
    "record:teaser:growth": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts teaser-growth",
    "record:teaser:skills-team": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts teaser-skills-team",
    "record:teaser:skills-me": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts teaser-skills-me",
    "record:teaser:moments": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts teaser-moments",
    "record:teaser:log": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts teaser-log",
    "record:teaser:reports": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts teaser-reports",
    "record:teaser:all": "bun run record:teaser:dashboard && bun run record:teaser:growth && bun run record:teaser:skills-team && bun run record:teaser:skills-me && bun run record:teaser:moments && bun run record:teaser:log && bun run record:teaser:reports",
    "trailer:v1": "remotion render studio/remotion/index.ts trailer-v1 public/studio/trailer-v1.mp4 --codec=h264 --crf=18",
    "trailer:v2": "remotion render studio/remotion/index.ts trailer-v2 public/studio/trailer-v2.mp4 --codec=h264 --crf=18",
    "trailer:both": "bun run trailer:v1 && bun run trailer:v2",
    "teaser:v2": "remotion render studio/remotion/index.ts teaser-v2 public/studio/teaser-v2.mp4 --codec=h264 --crf=18",
    "teaser:poster": "remotion still studio/remotion/index.ts teaser-v2 public/studio/teaser-v2-poster.jpg --frame=200 --image-format=jpeg --jpeg-quality=92",
    "render:og": "bun scripts/render-og.ts",
    "presentation:vo": "bun studio/scripts/generate-vo.ts",
    "record:presentation:employee-detail": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts presentation-employee-detail",
    "record:presentation:challenges": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts presentation-challenges",
    "record:presentation:skills-team": "AUDIO=audio/__skip__.mp3 bun studio/recordings/scripts/run.ts presentation-skills-team",
    "record:presentation:all": "bun run record:presentation:employee-detail && bun run record:presentation:challenges && bun run record:presentation:skills-team",
    "record:presentation:shorts:employee-detail": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts presentation-employee-detail",
    "record:presentation:shorts:challenges": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts presentation-challenges",
    "record:presentation:shorts:skills-team": "AUDIO=audio/__skip__.mp3 MOBILE=1 bun studio/recordings/scripts/run.ts presentation-skills-team",
    "record:presentation:shorts:all": "bun run record:presentation:shorts:employee-detail && bun run record:presentation:shorts:challenges && bun run record:presentation:shorts:skills-team",
    "presentation:1080": "remotion render studio/remotion/index.ts presentation-core-1080 public/studio/presentation/presentation-1080.mp4 --codec=h264 --crf=18 --gl=angle",
    "presentation:shorts": "remotion render studio/remotion/index.ts presentation-core-shorts public/studio/presentation/presentation-shorts.mp4 --codec=h264 --crf=18 --gl=angle",
    "presentation:1080:poster": "remotion still studio/remotion/index.ts presentation-core-1080 public/studio/presentation/presentation-1080-poster.jpg --frame=60 --image-format=jpeg --jpeg-quality=92 --gl=angle",
    "presentation:shorts:poster": "remotion still studio/remotion/index.ts presentation-core-shorts public/studio/presentation/presentation-shorts-poster.jpg --frame=60 --image-format=jpeg --jpeg-quality=92 --gl=angle",
    "presentation:both": "bun run presentation:1080 && bun run presentation:shorts",
    "presentation:all": "bun run presentation:both && bun run presentation:1080:poster && bun run presentation:shorts:poster"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@paper-design/shaders-react": "^0.0.76",
    "@pulse-hr/tokens": "workspace:*",
    "@remotion/bundler": "^4.0.400",
    "@remotion/cli": "^4.0.400",
    "@remotion/google-fonts": "^4.0.400",
    "@remotion/renderer": "^4.0.400",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.1.8",
    "lucide-astro": "^0.556.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.400",
    "tailwindcss": "^4.2.2",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "music-tempo": "^1.0.3",
    "playwright": "^1.48.0",
    "rehype-mermaid": "^3.0.0",
    "testreel": "latest",
    "typescript": "^5.6.3"
  }
}
