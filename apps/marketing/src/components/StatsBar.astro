---
import { useI18n } from "../i18n";
import { getLanding } from "../data/landing";

const { locale, t } = useI18n(Astro);
const { STATS } = getLanding(locale);
---

<section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20" aria-label={t.a11y.keyStats}>
  <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 list-none p-0 m-0">
    {STATS.map((s) => (
      <div class="border-l-2 border-[#b4ff39]/40 pl-5 py-2">
        <dt class="sr-only">{s.l}</dt>
        <dd class="m-0">
          <span class="font-display fluid-h2 block">{s.v}</span>
          <span class="text-sm text-white/60 mt-1 block">{s.l}</span>
        </dd>
      </div>
    ))}
  </dl>
</section>
