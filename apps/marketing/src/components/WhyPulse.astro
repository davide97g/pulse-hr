---
import { Code2, Package, Plug, Keyboard, ArrowRight } from "lucide-astro";
import { useI18n } from "../i18n";

const { t, href } = useI18n(Astro);
const GITHUB_REPO = "davide97g/pulse-hr";

const icons = [Code2, Package, Plug, Keyboard];
const hrefs = [href("/open-source"), href("/modules"), href("/ecosystem"), href("/keyboard")];
const values = t.whyPulse.values.map((v, i) => ({ ...v, icon: icons[i], href: hrefs[i] }));
---

<section id="why" class="max-w-[1280px] mx-auto px-6 py-24" aria-labelledby="why-title">
  <div class="max-w-2xl mb-14">
    <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4">{t.whyPulse.eyebrow}</p>
    <h2 id="why-title" class="font-display text-5xl md:text-6xl leading-[1.02] tracking-tight">
      {t.whyPulse.title.before}<br />{t.whyPulse.title.after}<em class="italic">{t.whyPulse.title.italic}</em>{t.whyPulse.title.end}
    </h2>
    <p class="mt-6 text-white/70 leading-relaxed">
      {t.whyPulse.subtitle.before}<a href={href("/vs")} class="text-[#b4ff39] hover:underline">{t.whyPulse.subtitle.link}</a>{t.whyPulse.subtitle.after}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {values.map((v) => (
      <a
        href={v.href}
        class="group block rounded-2xl border border-white/10 bg-[#0f0f11] hover:bg-[#141418] hover:border-[#b4ff39]/30 transition-colors p-8"
      >
        <div class="flex items-center gap-3 mb-6">
          <span class="h-10 w-10 rounded-lg border border-white/10 bg-white/[0.03] grid place-items-center">
            <v.icon class="h-5 w-5 text-[#b4ff39]" />
          </span>
          <h3 class="font-display text-3xl">{v.k}</h3>
        </div>
        <p class="text-white/70 leading-relaxed mb-6">{v.p}</p>
        <p class="inline-flex items-center gap-2 text-sm text-[#b4ff39] font-mono m-0">
          {v.cta}
          <ArrowRight class="h-4 w-4 group-hover:translate-x-0.5 transition-transform" />
        </p>
      </a>
    ))}
  </div>

  <div class="mt-10 flex items-center gap-3 flex-wrap text-xs text-white/40">
    <span class="font-mono uppercase tracking-[0.2em]">{t.whyPulse.source}</span>
    <a href={`https://github.com/${GITHUB_REPO}`} class="text-white/60 hover:text-white font-mono">github.com/{GITHUB_REPO}</a>
  </div>
</section>
