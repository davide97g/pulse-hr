---
import { useI18n } from "../i18n";
import { ArrowRight, Youtube } from "lucide-astro";
const { t, href } = useI18n(Astro);
---

<section class="relative" aria-label={t.heroReel.ariaLabel}>
  <div class="relative max-w-[1280px] mx-auto px-6 pb-16 -mt-6">
    <div
      class="relative rounded-2xl border border-white/10 overflow-hidden bg-[#0b0b0d] shadow-[0_40px_120px_-20px_rgba(180,255,57,0.25)] hero-reel"
      style="aspect-ratio: 16 / 9;"
    >
      <video
        class="hero-reel-video w-full h-full object-cover block"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/studio/poster.jpg"
        aria-label={t.heroReel.videoLabel}
      >
        <source src="/studio/teaser-v2.mp4" type="video/mp4" />
      </video>
      <img
        class="hero-reel-poster w-full h-full object-cover absolute inset-0"
        src="/studio/poster.jpg"
        alt={t.heroReel.posterAlt}
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(180deg, transparent 60%, rgba(11,11,13,0.5) 100%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute bottom-4 left-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-black/50 px-3 py-1 text-xs text-white/70 font-mono uppercase tracking-[0.2em]"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-[#b4ff39] pulse-dot"></span>
        {t.heroReel.caption}
      </div>
    </div>

    <div class="mt-5 flex flex-col sm:flex-row sm:items-center sm:justify-center gap-3">
      <a
        href={href("/blog/teaser-trailer")}
        class="group inline-flex items-center justify-center gap-2 rounded-md border border-[#b4ff39]/40 bg-[#b4ff39]/10 hover:bg-[#b4ff39]/15 px-5 py-3 font-medium text-[#b4ff39] press-scale transition-colors"
        data-analytics="hero-reel-blog"
      >
        <span class="inline-flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-[#b4ff39] pulse-dot" aria-hidden="true"></span>
          {t.heroReel.blogCta}
        </span>
        <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
      </a>
      <a
        href="https://www.youtube.com/watch?v=ZagF6Ri3eks"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-md border border-white/15 bg-white/[0.04] hover:bg-white/[0.08] px-5 py-3 font-medium text-white press-scale transition-colors"
        data-analytics="hero-reel-youtube"
      >
        <Youtube class="h-4 w-4 text-[#ff5e5e]" />
        {t.heroReel.youtubeCta}
      </a>
    </div>
  </div>
</section>

<style>
  .hero-reel-poster { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .hero-reel-video { display: none; }
    .hero-reel-poster { display: block; }
  }
</style>
