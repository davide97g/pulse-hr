---
import { useI18n } from "../i18n";
const { t } = useI18n(Astro);
---

<section class="relative" aria-label={t.heroReel.ariaLabel}>
  <div class="relative max-w-[1280px] mx-auto px-6 pb-16 -mt-6">
    <div
      class="relative rounded-2xl border border-white/10 overflow-hidden bg-[#0b0b0d] shadow-[0_40px_120px_-20px_rgba(180,255,57,0.25)] hero-reel"
      style="aspect-ratio: 16 / 9;"
    >
      <video
        class="hero-reel-video w-full h-full object-cover block"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/studio/poster.jpg"
        aria-label={t.heroReel.videoLabel}
      >
        <source src="/studio/reel.webm" type="video/webm" />
        <source src="/studio/reel.mp4" type="video/mp4" />
      </video>
      <img
        class="hero-reel-poster w-full h-full object-cover absolute inset-0"
        src="/studio/poster.jpg"
        alt={t.heroReel.posterAlt}
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(180deg, transparent 60%, rgba(11,11,13,0.5) 100%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute bottom-4 left-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-black/50 px-3 py-1 text-xs text-white/70 font-mono uppercase tracking-[0.2em]"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-[#b4ff39] pulse-dot"></span>
        {t.heroReel.caption}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-reel-poster { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .hero-reel-video { display: none; }
    .hero-reel-poster { display: block; }
  }
</style>
