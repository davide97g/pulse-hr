---
import {
  Clock, Wallet, Users, Briefcase, BarChart3, Plug,
  Gauge, Sparkles, Trophy,
} from "lucide-astro";
import { useI18n } from "../i18n";
import { getLanding } from "../data/landing";

const { locale, t } = useI18n(Astro);
const { FEATURES } = getLanding(locale);

const ICONS: Record<string, any> = {
  Clock, Wallet, Users, Briefcase, BarChart3, Plug, Gauge, Sparkles, Trophy,
};
---

<section id="features" class="max-w-[1280px] mx-auto px-6 py-24" aria-labelledby="features-title">
  <div class="flex items-end justify-between gap-8 mb-16 flex-wrap">
    <div class="max-w-2xl">
      <p class="text-xs uppercase tracking-[0.25em] text-[#b4ff39] mb-4">{t.features.eyebrow}</p>
      <h2 id="features-title" class="font-display text-5xl md:text-6xl leading-[1.02] tracking-tight">
        {t.features.title}
      </h2>
    </div>
    <p class="text-white/60 max-w-md text-sm leading-relaxed">
      {t.features.subtitle}
    </p>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {FEATURES.map((f) => {
      const Icon = ICONS[f.icon];
      return (
        <article class="group rounded-xl border border-white/8 bg-white/[0.02] p-6 hover:bg-white/[0.04] hover:border-[#b4ff39]/30 transition-all press-scale">
          <div class="h-10 w-10 rounded-md bg-[#b4ff39]/10 text-[#b4ff39] grid place-items-center mb-5 group-hover:bg-[#b4ff39] group-hover:text-[#0b0b0d] transition-colors">
            <Icon class="h-5 w-5" />
          </div>
          <h3 class="font-display text-2xl mb-2">{f.title}</h3>
          <p class="text-sm text-white/60 leading-relaxed">{f.body}</p>
        </article>
      );
    })}
  </div>
</section>
