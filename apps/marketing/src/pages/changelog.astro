---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getLanding } from "../data/landing";
import { useI18n } from "../i18n";

const { locale, t } = useI18n(Astro);
const { CHANGELOG } = getLanding(locale);

const breadcrumbs = [{ name: t.changelogPage.breadcrumb, path: "/changelog" }];

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": "https://pulsehr.it/changelog#collection",
  name: t.changelogPage.title,
  url: "https://pulsehr.it/changelog",
  description: t.changelogPage.description,
  isPartOf: { "@id": "https://pulsehr.it/#software" },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: CHANGELOG.map((c, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: c.t,
      description: `${c.k} · ${c.d}`,
    })),
  },
};

const extraLd = [collectionLd];
---

<BaseLayout title={t.changelogPage.title} description={t.changelogPage.description} path="/changelog" {breadcrumbs} {extraLd}>
  <Nav />
  <main id="main">
    <section class="max-w-[960px] mx-auto px-6 pt-20 pb-10">
      <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4">
        {t.changelogPage.eyebrow}
      </p>
      <h1 class="font-display text-[56px] md:text-[80px] leading-[0.95] tracking-tight">
        {t.changelogPage.titleBefore} <em class="italic text-[#b4ff39]">{t.changelogPage.titleItalic}</em>{t.changelogPage.titleAfter}
      </h1>
      <p class="mt-6 max-w-xl text-white/70 text-lg leading-relaxed">
        {t.changelogPage.body}
      </p>
    </section>

    <section class="max-w-[960px] mx-auto px-6 pb-20">
      <ol class="relative border-l border-white/10 ml-3 space-y-8 list-none p-0">
        {CHANGELOG.map((e) => (
          <li class="relative pl-8">
            <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full bg-[#b4ff39] ring-4 ring-[#0b0b0d]" aria-hidden="true"></span>
            <div class="flex items-baseline gap-3 flex-wrap mb-2">
              <time class="font-mono text-xs text-white/40 tabular-nums w-16">{e.d}</time>
              <span class="text-[10px] font-mono uppercase tracking-[0.18em] text-[#b4ff39] border border-[#b4ff39]/30 px-1.5 py-0.5 rounded-sm">
                {e.k}
              </span>
              <h2 class="font-display text-2xl md:text-3xl m-0">{e.t}</h2>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </main>
  <Footer />
</BaseLayout>
