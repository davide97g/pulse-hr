---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Cta from "../components/Cta.astro";
import { Shield, Lock, Globe2, Key, FileSearch, AlertTriangle, CheckCircle2, Clock } from "lucide-astro";

const title = "Security — how Pulse HR protects your data";
const description =
  "SOC 2 Type II in progress, GDPR-by-design, EU data residency, encryption at rest + in transit, full audit log, responsible-disclosure program. Technical detail, not a brochure.";
const path = "/security";
const keywords = "HR security, SOC 2, GDPR HR, EU data residency, ISO 27001 HR, HR responsible disclosure";

type CertStatus = "certified" | "in-progress" | "roadmap";

const CERTS: { k: string; status: CertStatus; d: string }[] = [
  { k: "SOC 2 Type II",  status: "in-progress", d: "Observation period started Q1 2026 with a Big-Four auditor. Report expected Q3 2026; available under NDA once issued." },
  { k: "GDPR",           status: "certified",   d: "GDPR-compliant by design. DPA templates auto-signed at sign-up. EU data residency available in Frankfurt, Dublin and Milan." },
  { k: "ISO 27001",      status: "roadmap",     d: "Gap analysis done. Target certification: H1 2027. Controls already mapped to ISO Annex A in the internal wiki." },
  { k: "HIPAA",          status: "roadmap",     d: "BAAs available on request today for US healthcare customers; full HIPAA self-assessment planned once the US customer base crosses 25." },
  { k: "CCPA",           status: "certified",   d: "Privacy policy, data-subject-access flows and deletion endpoints meet CCPA. California users can request their data via /settings → privacy." },
];

const CONTROLS = [
  { icon: Lock,       k: "Encryption",        d: "AES-256 at rest (RDS + S3-encrypted buckets). TLS 1.3 in transit. Customer-managed keys available on the Self-host tier." },
  { icon: Globe2,     k: "Data residency",    d: "Choose Frankfurt (eu-central-1), Dublin (eu-west-1) or Milan (it-south-1) at sign-up. Data never replicates out of the chosen region." },
  { icon: Key,        k: "Access control",    d: "SSO via SAML 2.0 (Okta, Entra, Google) or OIDC, included on every tier. SCIM provisioning. Granular role-based permissions with audit on every read and write." },
  { icon: FileSearch, k: "Audit log",         d: "Immutable, append-only log of every state change — who, what, when, from what IP. Exportable via API. Retention 6 years by default." },
  { icon: Shield,     k: "Tenant isolation",  d: "Logical separation at the DB row level with tenant_id in every foreign key. Row-level security policies enforced at Postgres." },
  { icon: AlertTriangle, k: "Incident playbook", d: "24/7 on-call rotation. P0 SLA: 15 min acknowledge, 2 h workaround. Public status page at status.pulsehr.com with incident post-mortems within 5 business days." },
];

const SUBPROCESSORS = [
  { n: "AWS",        purpose: "Compute, storage, DB (EU regions only unless you opt in)", region: "eu-central-1, eu-west-1" },
  { n: "Cloudflare", purpose: "CDN, DDoS protection, WAF",                                 region: "Global edge" },
  { n: "Stripe",     purpose: "Payments and invoicing",                                    region: "EU" },
  { n: "Postmark",   purpose: "Transactional email",                                       region: "EU" },
  { n: "Sentry",     purpose: "Error tracking (self-hosted on our infra)",                 region: "eu-central-1" },
  { n: "PagerDuty",  purpose: "On-call routing",                                           region: "EU" },
];

const statusBadge = {
  certified:     { c: "#b4ff39", l: "Certified",    I: CheckCircle2 },
  "in-progress": { c: "#ffbf4a", l: "In progress",  I: Clock },
  roadmap:       { c: "#6fd8ff", l: "Roadmap",      I: AlertTriangle },
};
---

<BaseLayout {title} {description} {path} {keywords}>
  <Nav />
  <main id="main">
    <section class="max-w-[1280px] mx-auto px-6 pt-20 pb-10">
      <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4 inline-flex items-center gap-2">
        <Shield class="h-3 w-3" /> Security
      </p>
      <h1 class="font-display text-[56px] md:text-[88px] leading-[0.95] tracking-tight max-w-4xl">
        The code is public.<br />
        So is<em class="italic text-[#b4ff39]"> how we secure it</em>.
      </h1>
      <p class="mt-6 max-w-2xl text-white/70 text-lg leading-relaxed">
        Open source doesn't mean casual about security — it means you can verify
        our claims. Every control below is implemented in the repo at
        <code class="font-mono text-[14px] text-[#b4ff39]">packages/*/</code> and
        <code class="font-mono text-[14px] text-[#b4ff39]">apps/app/src/lib/security/</code>.
        No "proprietary architecture" hand-waving.
      </p>
    </section>

    <section class="max-w-[1280px] mx-auto px-6 py-10">
      <h2 class="font-display text-3xl tracking-tight mb-6">Certifications — status-honest.</h2>
      <div class="rounded-2xl border border-white/10 bg-[#0f0f11] overflow-hidden">
        <table class="w-full">
          <tbody>
            {CERTS.map((c, i) => {
              const s = statusBadge[c.status];
              return (
                <tr class={i % 2 === 0 ? "bg-white/[0.01]" : ""}>
                  <td class="px-5 py-4 border-r border-white/5 w-[180px] align-top">
                    <div class="font-display text-lg">{c.k}</div>
                  </td>
                  <td class="px-5 py-4 border-r border-white/5 w-[150px] align-top">
                    <span class="inline-flex items-center gap-1.5 font-mono uppercase text-[11px] tracking-[0.15em]" style={`color:${s.c}`}>
                      <s.I class="h-3.5 w-3.5" />
                      {s.l}
                    </span>
                  </td>
                  <td class="px-5 py-4 text-sm text-white/70 leading-relaxed">{c.d}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section class="max-w-[1280px] mx-auto px-6 py-10">
      <h2 class="font-display text-3xl tracking-tight mb-6">Controls.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
        {CONTROLS.map((c) => (
          <article class="rounded-2xl border border-white/10 bg-[#0f0f11] p-5">
            <c.icon class="h-5 w-5 text-[#b4ff39] mb-3" />
            <h3 class="font-display text-lg mb-2 m-0">{c.k}</h3>
            <p class="text-[13px] text-white/65 leading-relaxed m-0">{c.d}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[1280px] mx-auto px-6 py-10">
      <h2 class="font-display text-3xl tracking-tight mb-2">Subprocessors.</h2>
      <p class="text-white/55 mb-6 max-w-2xl text-sm">
        Anyone we rely on who ever touches customer data. Public by design —
        changes ship with 30 days' notice via the mailing list and an RSS feed at
        <a href="/changelog" class="text-[#b4ff39] hover:underline">/changelog</a>.
      </p>
      <div class="rounded-2xl border border-white/10 bg-[#0f0f11] overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 text-white/60">
              <th class="text-left px-5 py-3 font-medium w-[180px]">Provider</th>
              <th class="text-left px-5 py-3 font-medium">Purpose</th>
              <th class="text-left px-5 py-3 font-medium w-[260px]">Region</th>
            </tr>
          </thead>
          <tbody>
            {SUBPROCESSORS.map((s, i) => (
              <tr class={i % 2 === 0 ? "bg-white/[0.01]" : ""}>
                <td class="px-5 py-3 text-white/85 border-r border-white/5 font-mono">{s.n}</td>
                <td class="px-5 py-3 text-white/70 border-r border-white/5">{s.purpose}</td>
                <td class="px-5 py-3 text-white/55 font-mono text-[13px]">{s.region}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="max-w-[960px] mx-auto px-6 py-16">
      <div class="rounded-2xl border border-white/10 bg-[#0f0f11] p-8">
        <div class="flex items-start gap-4 mb-6">
          <AlertTriangle class="h-6 w-6 text-[#ff8a7a] shrink-0 mt-1" />
          <div>
            <h2 class="font-display text-3xl tracking-tight mb-2 m-0">Responsible disclosure.</h2>
            <p class="text-white/65 leading-relaxed m-0">
              Found a vulnerability? Tell us privately first — we'll fix it, credit
              you publicly, and never threaten legal action against researchers
              acting in good faith.
            </p>
          </div>
        </div>

        <ul class="space-y-3 text-sm text-white/75 list-none p-0 m-0">
          <li class="flex items-start gap-3">
            <span class="font-mono text-[#b4ff39] shrink-0 w-[100px]">Contact</span>
            <a href="mailto:security@pulsehr.com" class="text-[#b4ff39] hover:underline">security@pulsehr.com</a>
          </li>
          <li class="flex items-start gap-3">
            <span class="font-mono text-[#b4ff39] shrink-0 w-[100px]">PGP key</span>
            <a href="/.well-known/security.txt" class="text-[#b4ff39] hover:underline">/.well-known/security.txt</a>
          </li>
          <li class="flex items-start gap-3">
            <span class="font-mono text-[#b4ff39] shrink-0 w-[100px]">SLA</span>
            <span>Initial reply within 24 h. Triage within 72 h. Fix or mitigation ETA within 7 days for critical issues.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="font-mono text-[#b4ff39] shrink-0 w-[100px]">Scope</span>
            <span>pulsehr.com, workflows-people.vercel.app, the GitHub repo, and any self-hosted deployment you control.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="font-mono text-[#b4ff39] shrink-0 w-[100px]">Reward</span>
            <span>Swag + public credit in the changelog for low/medium; €200–€2,000 for high/critical, paid from our own wallet (no bug-bounty platform overhead).</span>
          </li>
        </ul>
      </div>
    </section>

    <Cta />
  </main>
  <Footer />
</BaseLayout>
