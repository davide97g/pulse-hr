---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import StatsBar from "../components/StatsBar.astro";
import Concepts from "../components/Concepts.astro";
import WhyPulse from "../components/WhyPulse.astro";
import Features from "../components/Features.astro";
import LabsSection from "../components/LabsSection.astro";
import KeyboardCopilot from "../components/KeyboardCopilot.astro";
import ProductPreview from "../components/ProductPreview.astro";
import RolesSection from "../components/RolesSection.astro";
import UseCases from "../components/UseCases.astro";
import Testimonials from "../components/Testimonials.astro";
import Changelog from "../components/Changelog.astro";
import TeamSection from "../components/TeamSection.astro";
import FaqSection from "../components/FaqSection.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Open-source HR, payroll & time tracking — Pulse HR"
  description="Open-source, modular HR & payroll. Money, People and Work as three composable products. Keyboard-first, webhooks on every event, free for the first 5 employees."
  path="/"
  isHome={true}
>
  <Nav />
  <main id="main">
    <Hero />
    <Marquee />
    <StatsBar />
    <WhyPulse />
    <Concepts />
    <Features />
    <LabsSection />
    <KeyboardCopilot />
    <ProductPreview />
    <RolesSection />
    <UseCases />
    <Testimonials />
    <Changelog />
    <TeamSection />
    <FaqSection />
    <Cta />
  </main>
  <Footer />
</BaseLayout>
