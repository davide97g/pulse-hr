---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Cta from "../components/Cta.astro";
import { Code2, Github, FileText, Server, GitFork, CheckCircle2 } from "lucide-astro";
import { useI18n } from "../i18n";

const GITHUB_REPO = "davide97g/pulse-hr";

const { t } = useI18n(Astro);
const title = t.openSourcePage.title;
const description = t.openSourcePage.description;
const path = "/open-source";

const faq = [
  {
    q: "What license is Pulse under?",
    a: "The MIT License — one of the most permissive open-source licenses there is. You get full source access from day one with permission to use, modify, redistribute and even sell, for any purpose, commercial or not. The only requirement is preserving the copyright and license notice. No competing-use clause, no time delay, no strings.",
  },
  {
    q: "Why MIT and not something more restrictive?",
    a: "We considered source-available licenses that fence off competitors, but decided the simplest, most trustworthy promise is a fully permissive one. MIT means you never have to wonder whether your use is allowed — it is. We'd rather earn the hosted business than wall off the code.",
  },
  {
    q: "Can I self-host the whole thing?",
    a: "Yes. The platform is a Bun workspace you can clone and run with `bun install && bun run build`. A reference Docker Compose setup and a Helm chart for Kubernetes are in the repo — every module runs on your infrastructure with no external dependency on us.",
  },
  {
    q: "Do I have to credit Pulse if I fork?",
    a: "Yes. The NOTICE file in the repo asks you to preserve the copyright header and include a visible attribution (\"Built on workflows-people by Davide Ghiotto\") in the About screen or docs of any public derivative work. No royalties, no paperwork — just a link back.",
  },
];
---

<BaseLayout {title} {description} {path}>
  <Nav />
  <main id="main">
    <section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-10">
      <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4 inline-flex items-center gap-2">
        <Code2 class="h-3 w-3" /> Open source
      </p>
      <h1 class="font-display leading-[0.95] tracking-tight fluid-hero max-w-4xl">
        HR you can<br />
        <em class="italic text-[#b4ff39]">read</em>, fork, run.
      </h1>
      <p class="mt-6 max-w-2xl text-white/70 text-lg leading-relaxed">
        The entire platform — app, marketing site, Bun workspace configuration,
        every line of logic — lives on GitHub under the MIT License. No "enterprise-only"
        source dump, no black-box core. What you run is what you can read.
      </p>

      <div class="mt-10 flex items-center gap-3 flex-wrap">
        <a
          href={`https://github.com/${GITHUB_REPO}`}
          class="group inline-flex items-center gap-2 bg-[#b4ff39] text-[#0b0b0d] px-5 py-3 rounded-md font-medium press-scale hover:bg-[#c6ff5a] transition-colors"
        >
          <Github class="h-4 w-4" />
          View on GitHub
        </a>
        <a
          href={`https://github.com/${GITHUB_REPO}/blob/main/LICENSE`}
          class="inline-flex items-center gap-2 border border-white/15 bg-white/[0.04] hover:bg-white/[0.08] px-5 py-3 rounded-md font-medium press-scale transition-colors"
        >
          <FileText class="h-4 w-4 text-[#b4ff39]" />
          Read LICENSE
        </a>
      </div>
    </section>

    <section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { icon: Github, k: "Public repo", p: `github.com/${GITHUB_REPO}. Issues, PRs, discussions — open to anyone. Merge conflicts resolved in public.` },
          { icon: Server, k: "Self-host", p: "Docker Compose for single-node, Helm chart for K8s clusters. Your data, your infra, your call on compliance boundaries." },
          { icon: GitFork, k: "Forkable", p: "Take the 20% that matches your workflow, throw away the 80% that doesn't. MIT allows it — for any purpose, today." },
        ].map((v) => (
          <article class="rounded-2xl border border-white/10 bg-[#0f0f11] p-6">
            <v.icon class="h-5 w-5 text-[#b4ff39] mb-4" />
            <h3 class="font-display text-2xl mb-2">{v.k}</h3>
            <p class="text-white/65 leading-relaxed text-sm">{v.p}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[960px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <h2 class="font-display fluid-h2 tracking-tight mb-8">The license, in one table.</h2>
      <div class="rounded-2xl border border-white/10 overflow-hidden">
        <table class="w-full text-sm">
          <tbody>
            {[
              ["Source visible", "Day one"],
              ["Run internally / self-host", "Day one, any scale"],
              ["Fork & modify for any purpose", "Day one"],
              ["Build a commercial product on it", "Allowed"],
              ["License", "MIT — fully permissive"],
              ["Attribution required", "Preserve the copyright + license notice"],
              ["Royalties / per-seat fees", "None, ever"],
            ].map(([k, v], i) => (
              <tr class={i % 2 === 0 ? "bg-white/[0.02]" : ""}>
                <td class="px-5 py-3 text-white/80 border-r border-white/5">{k}</td>
                <td class="px-5 py-3 text-white/60 font-mono text-[13px]">
                  <CheckCircle2 class="inline h-3.5 w-3.5 text-[#b4ff39] mr-2 -mt-0.5" />
                  {v}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="max-w-[960px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <h2 class="font-display fluid-h2 tracking-tight mb-10">Honest answers.</h2>
      <div class="space-y-6">
        {faq.map((f) => (
          <details class="rounded-xl border border-white/10 bg-[#0f0f11] p-6 group">
            <summary class="cursor-pointer font-display text-xl text-white group-open:text-[#b4ff39] transition-colors list-none">
              {f.q}
            </summary>
            <p class="mt-4 text-white/70 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <Cta />
  </main>
  <Footer />
</BaseLayout>
