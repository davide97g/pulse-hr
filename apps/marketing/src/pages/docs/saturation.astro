---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { Gauge } from "lucide-astro";

const title = "Saturation — Pulse HR docs";
const description =
  "How busy the org is, who's leaning in, and what each hour returns. Utilisation heatmap, trend chart, project margins, cost-vs-revenue scatter, and the Insights triage surface.";
const path = "/docs/saturation";

const SECTIONS = [
  {
    t: "Team load",
    body: [
      `The <strong>utilisation heatmap</strong> shows one row per person, one column per upcoming week, and each cell is the sum of their allocation percentages in that week. Green is healthy, amber means over, red means burnout territory. Blank = bench.`,
      `Next to it, the <strong>trend chart</strong> draws a line per employee using their avatar colour. Hover any row, line or legend item and the rest dim — good for isolating a single person across the team.`,
    ],
  },
  {
    t: "Project margins",
    body: [
      `Revenue − cost, summed per project year-to-date. Bars in the project's own colour are net-positive; red bars are net-negative. Feed projects into this view by adding allocations with rates in the <a href="/docs/clients-projects" class="text-[#b4ff39] hover:underline">Clients &amp; Projects</a> area.`,
    ],
    note: "Cost = employee salary ÷ 1,800h baseline. Revenue = allocation % × rate × hours.",
  },
  {
    t: "Employee value",
    body: [
      `A scatter plot of cost vs revenue per person. Upper-right = expensive and profitable; upper-left = leverage points; lower-right = watch list. Dot size scales with hours delivered.`,
    ],
  },
  {
    t: "Insights",
    body: [
      `A triage surface showing only the problems worth acting on today: losing projects, over-budget burn, at-risk and on-hold flags, people on the bench or overbooked, declining forward load, and low-health clients. Each row is severity-coded and deep-links to the relevant project where applicable.`,
    ],
  },
];
---

<DocsLayout {title} {description} {path}>
  <div class="flex items-center gap-3 mb-6">
    <span class="h-10 w-10 rounded-lg bg-[#6fd8ff]/15 text-[#6fd8ff] grid place-items-center">
      <Gauge class="h-5 w-5" />
    </span>
    <div>
      <h1 class="font-display text-4xl md:text-5xl tracking-tight m-0">Saturation</h1>
      <p class="text-sm text-white/50 mt-1 m-0">How busy the org is, who's leaning in, and what each hour returns.</p>
    </div>
  </div>

  <div class="space-y-4">
    {SECTIONS.map((s) => (
      <section class="rounded-2xl border border-white/10 bg-[#0f0f11] p-6">
        <h2 class="font-display text-xl tracking-tight mb-3 m-0">{s.t}</h2>
        <div class="space-y-3 text-white/75 leading-relaxed text-[15px]">
          {s.body.map((p) => <p set:html={p} class="m-0" />)}
          {s.note && <p class="text-[12px] text-white/45 mt-2 m-0">{s.note}</p>}
        </div>
      </section>
    ))}
  </div>
</DocsLayout>
