---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Cta from "../components/Cta.astro";
import { Scale, ArrowRight, AlertTriangle } from "lucide-astro";
import { useI18n } from "../i18n";

const { t } = useI18n(Astro);
const title = t.vsPage.title;
const description = t.vsPage.description;
const path = "/vs";

// We don't compare against named products. We compare against *patterns of
// invisibility* — the gap in everyone's working life that no current tool
// fills well, regardless of which HR product their company pays for. See
// docs/brand/foundation.md §7.
type Pattern = {
  k: string;
  /** The familiar shape of the problem — described, not named. */
  today: string;
  /** What Pulse does instead. Concrete surface, never an abstract claim. */
  pulse: string;
};

const PATTERNS: Pattern[] = [
  {
    k: "Standup ritual",
    today:
      "A six-person commute to a video call where one person talks. Nobody remembers what was said by Friday, and the artefact (if any) is a Notion page nobody opens twice.",
    pulse:
      "Status Log: three written lines per person, public team feed, ⌘⏎ to publish. Six minutes once instead of thirty minutes daily.",
  },
  {
    k: "Recognition",
    today:
      "A #kudos Slack channel that gets six messages a month, scrolls off in a week, and contributes zero to the conversation in performance review season.",
    pulse:
      "Kudos with a one-line reason, a tag (craft, kindness, impact), and a coin. Lives inside Growth, feeds the Recognition factor on the Employee Score, survives the year.",
  },
  {
    k: "Performance review",
    today:
      "A textarea asking an IC to summarise twelve months in a paragraph. They scroll through Slack the night before, screenshot, submit, lose.",
    pulse:
      "A growth trail built from what the IC actually did — status log entries, kudos received, achievements unlocked, skill paths progressed. The review writes itself from artefacts they own.",
  },
  {
    k: "Engagement survey",
    today:
      "A 32-question quarterly survey, results in a slide deck that lands in everyone's inbox eight weeks later. Action items: zero.",
    pulse:
      "Anonymous weekly Pulse vibe heatmap, embedded inside Status Log. Shows only when three or more people answer. No 32-question form, no eight-week lag.",
  },
  {
    k: "1:1 prep",
    today:
      "A shared doc both parties open ten minutes before the meeting. Half-written agenda, no record of what was discussed last time, no idea what's changed since.",
    pulse:
      "The IC walks in with their Status Log of the week, their kudos volume, their workload check-in trend. The manager walks in having read the same. The hour is for the work, not the catch-up.",
  },
  {
    k: "Workload visibility",
    today:
      "The manager guesses. The IC says they're fine. Two weeks later someone burns out and the team learns the answer in a 1:1.",
    pulse:
      "One-tap weekly check-in — light, balanced, heavy, overloaded. Eight-week sparkline. Manager sees the trend, not the individual answers.",
  },
  {
    k: "Time off",
    today:
      "An approval workflow nobody understands, a balance the IC has to calculate themselves, and a 'pending' state that sits for three days.",
    pulse:
      "Personal leave journal. The IC logs it, it's logged. No approval queue, no pending state. Balance is visible to them alone.",
  },
  {
    k: "Onboarding",
    today:
      "A shared drive with twelve folders. The new hire opens four, gets confused, asks the same five questions every new hire has asked for three years.",
    pulse:
      "Out of scope on purpose. Onboarding workflows belong in the tool built for them — Pulse runs alongside the HRIS, not in place of it. See §3 below for what we don't ship.",
  },
];

// Where Pulse is genuinely weaker. The /vs page that doesn't show our losses
// is a lie (foundation.md §11). These are framed as use cases — a person
// reading this should be able to recognise themselves and pick the right tool.
const NOT_FOR = [
  {
    k: "Compliance over visibility",
    body:
      "If your biggest people-ops problem is producing audit trails for a regulator, you need a compliance product. Pulse is built for the moment of pain that comes after — the IC who can't show their year.",
  },
  {
    k: "Formal performance management",
    body:
      "Pulse doesn't run calibration cycles, doesn't ship 360 review templates, doesn't model OKR cascades down a six-level org chart. If those are the rituals your organisation runs on, you'll be happier with a tool built for them.",
  },
  {
    k: "All-in-one HRIS replacement",
    body:
      "We've parked payroll, time tracking, recruiting, documents, and project allocation on purpose. If you want one vendor for all of HR, we're explicitly not it. Pulse runs alongside your HRIS, not in place of it.",
  },
  {
    k: "Sales-led procurement",
    body:
      "There's no enterprise tier with extra features, no demo gate, no quarterly business review. The OSS is the whole product. If your buying process requires a sales call before you try the thing, that's a process mismatch.",
  },
];
---

<BaseLayout {title} {description} {path}>
  <Nav />
  <main id="main">
    <section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-10">
      <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4 inline-flex items-center gap-2">
        <Scale class="h-3 w-3" /> Honest comparison
      </p>
      <h1 class="font-display fluid-hero leading-[0.95] tracking-tight max-w-4xl">
        We don't compete with<br />
        <em class="italic text-[#b4ff39]">other tools</em>.
      </h1>
      <p class="mt-6 max-w-2xl text-white/70 text-lg leading-relaxed">
        We compete with the pattern of invisibility — the shared doc nobody opens,
        the kudos that scrolls off, the review that fits a year into a textarea.
        Whichever HR app your company pays for, that gap is still there. Pulse fills
        it. Below: eight shapes the problem takes, and what we ship instead.
      </p>
    </section>

    <section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <ol class="space-y-3 list-none p-0 m-0">
        {PATTERNS.map((p, i) => (
          <li class="rounded-2xl border border-white/10 bg-[#0f0f11] overflow-hidden">
            <div class="grid grid-cols-1 lg:grid-cols-[180px_1fr_1fr]">
              <div class="px-5 py-5 lg:py-6 border-b lg:border-b-0 lg:border-r border-white/10 bg-white/[0.02]">
                <p class="font-mono uppercase tracking-[0.2em] text-[10px] text-white/40 m-0">#{String(i + 1).padStart(2, "0")}</p>
                <h2 class="font-display text-lg md:text-xl tracking-tight mt-1 mb-0">{p.k}</h2>
              </div>
              <div class="px-5 py-5 lg:py-6 border-b lg:border-b-0 lg:border-r border-white/10">
                <p class="font-mono uppercase tracking-[0.2em] text-[10px] text-white/40 mb-2 m-0">The pattern today</p>
                <p class="text-[14px] text-white/70 leading-relaxed m-0">{p.today}</p>
              </div>
              <div class="px-5 py-5 lg:py-6">
                <p class="font-mono uppercase tracking-[0.2em] text-[10px] text-[#b4ff39] mb-2 m-0 inline-flex items-center gap-2">
                  What Pulse ships <ArrowRight class="h-3 w-3" />
                </p>
                <p class="text-[14px] text-white/85 leading-relaxed m-0">{p.pulse}</p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="max-w-2xl mb-10">
        <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#ffbf4a] mb-4 inline-flex items-center gap-2">
          <AlertTriangle class="h-3 w-3" /> Where we're a bad fit
        </p>
        <h2 class="font-display fluid-h2 tracking-tight leading-[1.05]">
          Honest losses.<br />
          <em class="italic text-[#ffbf4a]">No</em> apologies.
        </h2>
        <p class="mt-6 text-white/70 leading-relaxed">
          Pulse is narrow on purpose. If one of the patterns below describes
          your situation, we're the wrong choice — and the right move is to
          keep using what you have.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {NOT_FOR.map((w) => (
          <article class="rounded-2xl border border-white/10 bg-[#0f0f11] p-6">
            <p class="font-mono uppercase tracking-[0.2em] text-[11px] text-[#ffbf4a] mb-2">Pulse is not for</p>
            <h3 class="font-display text-2xl mb-3">{w.k}</h3>
            <p class="text-white/70 leading-relaxed text-[14px]">{w.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[960px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-5">
        The one-line decision.
      </h2>
      <p class="text-white/75 leading-relaxed text-lg">
        If your best work disappears into a Slack thread three weeks after you
        ship it, and you're tired of reconstructing your year from screenshots
        — Pulse is the workspace built for that. Open source. Self-host in 90
        seconds. The demo is the sales call.
      </p>
      <a href="https://app.pulsehr.it/" class="mt-8 inline-flex items-center gap-2 bg-[#b4ff39] text-[#0b0b0d] px-5 py-3 rounded-md font-medium press-scale hover:bg-[#c6ff5a] transition-colors">
        Open the demo
        <ArrowRight class="h-4 w-4" />
      </a>
    </section>

    <Cta />
  </main>
  <Footer />
</BaseLayout>
