---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Cta from "../components/Cta.astro";
import { Scale, CheckCircle2, XCircle, MinusCircle, AlertTriangle } from "lucide-astro";

const title = "Pulse HR vs Lattice, 15Five, Officevibe — honest comparison";
const description =
  "Honest comparison of Pulse HR against the engagement-tool incumbents — Lattice, 15Five, Officevibe and Culture Amp. Open source, scope, async-first, manager-safe sentiment, pricing — plus where each of them is genuinely stronger.";
const path = "/vs";

const VENDORS = [
  { k: "pulse",      n: "Pulse HR",      self: true  },
  { k: "lattice",    n: "Lattice",       self: false },
  { k: "fifteen",    n: "15Five",        self: false },
  { k: "officevibe", n: "Officevibe",    self: false },
  { k: "cultureamp", n: "Culture Amp",   self: false },
];

type Cell = "yes" | "partial" | "no";

interface Row {
  cat: string;
  q: string;
  n?: string;
  cells: Record<string, Cell>;
}

const ROWS: Row[] = [
  // Scope clarity
  { cat: "Scope", q: "Stays out of payroll, time tracking, project allocation",
    n: "Pulse doesn't try to be an HRIS. The others bundle modules that creep into business ops.",
    cells: { pulse: "yes", lattice: "partial", fifteen: "partial", officevibe: "yes", cultureamp: "partial" } },
  { cat: "Scope", q: "Built around continuous signal, not yearly review cycles",
    cells: { pulse: "yes", lattice: "partial", fifteen: "yes", officevibe: "yes", cultureamp: "no" } },
  { cat: "Scope", q: "Async-first (no meetings required to use)",
    cells: { pulse: "yes", lattice: "no", fifteen: "partial", officevibe: "no", cultureamp: "no" } },
  { cat: "Scope", q: "Manager-safe sentiment (raw chat stays with the employee)",
    n: "Pulse never exposes individual chat to the manager — only sentiment dimensions.",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "partial", cultureamp: "partial" } },

  // Open source
  { cat: "Open source", q: "Source code public",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Open source", q: "Permissive future license (converts to MIT after 2 years)",
    n: "Pulse is FSL-1.1-MIT — every release becomes plain MIT after two years.",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Open source", q: "Self-host on your own infra",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Open source", q: "Public issue tracker / accept PRs",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },

  // Daily-driver UX
  { cat: "Daily-driver UX", q: "⌘K global fuzzy search",
    cells: { pulse: "yes", lattice: "partial", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Daily-driver UX", q: "Natural-language command bar (⌘J)",
    n: "Local deterministic parser — no LLM, works offline.",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Daily-driver UX", q: "Offline PWA (works on a plane)",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Daily-driver UX", q: "One-tap weekly workload check-in",
    n: "Pulse: four emoji buttons, no form. Most engagement tools bury this inside a 5-question survey.",
    cells: { pulse: "yes", lattice: "no", fifteen: "partial", officevibe: "yes", cultureamp: "no" } },

  // Ecosystem
  { cat: "Ecosystem", q: "Public REST API (included on every tier)",
    cells: { pulse: "yes", lattice: "partial", fifteen: "partial", officevibe: "no", cultureamp: "partial" } },
  { cat: "Ecosystem", q: "Webhooks on every resource event",
    cells: { pulse: "yes", lattice: "partial", fifteen: "no", officevibe: "no", cultureamp: "partial" } },
  { cat: "Ecosystem", q: "API access without enterprise upsell",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Ecosystem", q: "Maintained SDKs (TS / Python / Go)",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },

  // Pricing & access
  { cat: "Pricing & access", q: "Free tier for small teams",
    n: "Pulse: free for the first 5 active employees, forever. No feature paywall.",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
  { cat: "Pricing & access", q: "Published per-seat price (no \"contact sales\")",
    cells: { pulse: "yes", lattice: "no", fifteen: "partial", officevibe: "partial", cultureamp: "no" } },
  { cat: "Pricing & access", q: "One tier — no enterprise unlock for SSO / API",
    cells: { pulse: "yes", lattice: "no", fifteen: "no", officevibe: "no", cultureamp: "no" } },
];

const WEAKNESSES = [
  {
    against: "Lattice",
    body: "Mature performance review and OKR cycles, calibration sessions, deep manager training content. Pick Lattice if your organisation is built around formal review cycles and you need a full Performance Management System.",
  },
  {
    against: "15Five",
    body: "Strong weekly 1:1 templates, structured manager coaching, larger US install base. Pick 15Five if your managers want a guided cadence for 1:1s and you're committed to that ritual.",
  },
  {
    against: "Officevibe",
    body: "Owned by Workleap, plugs into Microsoft Teams natively, deep survey question bank, mature anonymous feedback collection. Pick Officevibe if you live in the Microsoft ecosystem and want surveys to be the centre of gravity.",
  },
  {
    against: "Culture Amp",
    body: "Enterprise-grade engagement surveys, benchmarking across 5,000+ companies, scientific-research backing on every question. Pick Culture Amp if you're a 1,000-person org running annual engagement programs and need defensible benchmarks.",
  },
];

const icon = {
  yes:     { I: CheckCircle2, c: "text-[#b4ff39]" },
  partial: { I: MinusCircle,  c: "text-[#ffbf4a]" },
  no:      { I: XCircle,      c: "text-white/30" },
};

const CATEGORIES = Array.from(new Set(ROWS.map((r) => r.cat)));
---

<BaseLayout {title} {description} {path}>
  <Nav />
  <main id="main">
    <section class="max-w-[1280px] mx-auto px-6 pt-20 pb-10">
      <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4 inline-flex items-center gap-2">
        <Scale class="h-3 w-3" /> Honest comparison
      </p>
      <h1 class="font-display text-[56px] md:text-[80px] leading-[0.95] tracking-tight max-w-4xl">
        Pulse HR vs<br />
        <em class="italic text-[#b4ff39]">the engagement tools</em>.
      </h1>
      <p class="mt-6 max-w-2xl text-white/70 text-lg leading-relaxed">
        Pulse is in the same category as Lattice, 15Five, Officevibe and
        Culture Amp — the employee-engagement and people-development tools, not
        the HRIS suites. We're narrower than they are on purpose, deeper on
        async-first UX, and the only one of the bunch that ships its source
        code under an open licence. Plus where they're genuinely stronger.
      </p>

      <div class="mt-8 flex items-center gap-5 flex-wrap text-sm text-white/60">
        <span class="inline-flex items-center gap-1.5">
          <CheckCircle2 class="h-4 w-4 text-[#b4ff39]" /> Fully supported
        </span>
        <span class="inline-flex items-center gap-1.5">
          <MinusCircle class="h-4 w-4 text-[#ffbf4a]" /> Partial / gated behind a tier
        </span>
        <span class="inline-flex items-center gap-1.5">
          <XCircle class="h-4 w-4 text-white/30" /> Not supported
        </span>
      </div>

      <p class="mt-6 text-[11px] text-white/40 font-mono uppercase tracking-[0.15em]">
        Based on publicly available docs &amp; pricing pages as of 2026-05-14. If anything below is stale, open an issue and we'll fix it.
      </p>
    </section>

    {CATEGORIES.map((cat) => {
      const rows = ROWS.filter((r) => r.cat === cat);
      return (
        <section class="max-w-[1280px] mx-auto px-6 py-8">
          <h2 class="font-display text-3xl tracking-tight mb-4">{cat}</h2>
          <div class="rounded-2xl border border-white/10 bg-[#0f0f11] overflow-hidden overflow-x-auto scrollbar-thin">
            <table class="w-full min-w-[860px] text-sm">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left px-5 py-3 font-medium text-white/70 w-[38%]">&nbsp;</th>
                  {VENDORS.map((v) => (
                    <th class:list={[
                      "text-center px-3 py-3 font-medium",
                      v.self ? "text-[#b4ff39] bg-[#b4ff39]/5" : "text-white/70",
                    ]}>
                      {v.n}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {rows.map((r, i) => (
                  <tr class={i % 2 === 0 ? "bg-white/[0.01]" : ""}>
                    <td class="px-5 py-3 text-white/85 border-r border-white/5">
                      <div>{r.q}</div>
                      {r.n && <div class="text-[11px] text-white/40 mt-1 leading-relaxed">{r.n}</div>}
                    </td>
                    {VENDORS.map((v) => {
                      const c = r.cells[v.k];
                      const I = icon[c].I;
                      return (
                        <td class:list={["text-center px-3 py-3", v.self ? "bg-[#b4ff39]/5" : ""]}>
                          <I class={`h-5 w-5 inline ${icon[c].c}`} />
                        </td>
                      );
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      );
    })}

    <section class="max-w-[1280px] mx-auto px-6 py-16">
      <div class="max-w-2xl mb-10">
        <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#ffbf4a] mb-4 inline-flex items-center gap-2">
          <AlertTriangle class="h-3 w-3" /> Where we're weaker
        </p>
        <h2 class="font-display text-4xl md:text-5xl tracking-tight leading-[1.05]">
          Every vendor<br />does <em class="italic text-[#ffbf4a]">something</em> better.
        </h2>
        <p class="mt-6 text-white/70 leading-relaxed">
          Pulse is opinionated. We don't have ten years of survey science, a
          calibration cycle product, or a 200-person Customer Success team.
          Here's when one of the incumbents is the right call.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {WEAKNESSES.map((w) => (
          <article class="rounded-2xl border border-white/10 bg-[#0f0f11] p-6">
            <p class="font-mono uppercase tracking-[0.2em] text-[11px] text-[#ffbf4a] mb-2">Pick them over us for</p>
            <h3 class="font-display text-2xl mb-3">{w.against}</h3>
            <p class="text-white/70 leading-relaxed text-[14px]">{w.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[960px] mx-auto px-6 py-20">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-5">
        The one-line decision tree.
      </h2>
      <ol class="space-y-3 text-white/75 leading-relaxed list-decimal list-inside">
        <li>If your organisation runs on <strong>formal performance reviews and OKRs</strong> → Lattice.</li>
        <li>If <strong>structured 1:1s</strong> are the ritual you want to build around → 15Five.</li>
        <li>If you live in <strong>Microsoft Teams and want surveys at the centre</strong> → Officevibe.</li>
        <li>If you're a <strong>1,000-person org running annual engagement programs</strong> → Culture Amp.</li>
        <li>
          If you want <strong>open source, async-first, manager-safe sentiment, no timesheets, real API</strong>,
          and your team should actually open the tool because it gives them something →
          <a href="/" class="text-[#b4ff39] hover:underline">Pulse HR</a>.
        </li>
      </ol>
    </section>

    <Cta />
  </main>
  <Footer />
</BaseLayout>
