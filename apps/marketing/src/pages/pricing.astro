---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Cta from "../components/Cta.astro";
import { Check, ArrowRight, Github, Server, Tag, Info } from "lucide-astro";
import { useI18n } from "../i18n";

const { t } = useI18n(Astro);
const title = t.pricingPage.title;
const description = t.pricingPage.description;

const path = "/pricing";

// Two ways to pay (foundation.md §12). The OSS is the whole product on both
// — no enterprise tier with extra features, no paid-only modules. The Hosted
// price buys uptime and the time you'd spend running it yourself, not unlocked
// capability. The Support SLA is an optional flat add-on for self-hosters who
// need a phone number.
const TIERS = [
  {
    id: "self-host",
    name: "Self-host",
    price: "€0",
    unit: "FSL-1.1-MIT — converts to MIT in 2 years",
    punch: "Run the whole platform on your own infra. `docker compose up` and you're done in 90 seconds.",
    cta: { label: "See on GitHub", href: "https://github.com/davide97g/pulse-hr" },
    included: [
      "Full source code, every surface, no paid-only modules",
      "Docker Compose reference (single-node)",
      "Helm chart for Kubernetes",
      "Terraform modules for AWS / GCP / Hetzner",
      "Public REST API, webhooks on every event",
      "Contribute back via PR — credited in the changelog",
    ],
    notIncluded: [
      "Commercial support SLA (see add-on below)",
      "Uptime guarantee (you run it, you guarantee it)",
    ],
    accent: "#6fd8ff",
    bg: "bg-[#0f0f11]",
    border: "border-white/10",
  },
  {
    id: "hosted",
    name: "Hosted",
    price: "€6",
    unit: "per active employee / month",
    punch: "Same product. We run the infra so you don't have to. EU data residency, daily backups, zero-downtime migrations.",
    cta: { label: "Open the demo", href: "https://app.pulsehr.it/" },
    featured: true,
    included: [
      "Everything in Self-host — same source, same features",
      "EU data residency (Frankfurt / Dublin)",
      "Daily backups, point-in-time restore",
      "Zero-downtime migrations on every release",
      "SAML SSO, SCIM provisioning, audit log",
      "Email support, response within one business day",
      "Annual billing: 15% off",
    ],
    notIncluded: [],
    accent: "#b4ff39",
    bg: "bg-[#141418]",
    border: "border-[#b4ff39]/40",
  },
  {
    id: "support",
    name: "Support SLA",
    price: "€400",
    unit: "per month — flat, optional add-on",
    punch: "For self-hosters who need a phone number. Same OSS, plus priority patches and guaranteed response times.",
    cta: { label: "Email sales@pulsehr.it", href: "mailto:sales@pulsehr.it" },
    included: [
      "Priority email response under 4 business hours",
      "Onboarding help: schema review, migration sanity check",
      "Priority security patches before public disclosure window closes",
      "Direct line to a maintainer (Davide or Niccolò)",
      "No seat limit — pay flat, regardless of team size",
    ],
    notIncluded: [
      "Custom development (we don't sell consulting)",
      "We host or operate your deployment",
    ],
    accent: "#ffffff",
    bg: "bg-[#0f0f11]",
    border: "border-white/10",
  },
];

const breadcrumbs = [{ name: "Pricing", path: "/pricing" }];

const offerCatalogLd = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  name: "Pulse HR pricing",
  url: "https://pulsehr.it/pricing",
  itemListElement: [
    {
      "@type": "Offer",
      name: "Self-host",
      price: "0",
      priceCurrency: "EUR",
      description: "Run the full platform on your own infra under the Functional Source License (FSL-1.1-MIT). The OSS is the whole product.",
      availability: "https://schema.org/InStock",
      url: "https://pulsehr.it/pricing#self-host",
    },
    {
      "@type": "Offer",
      name: "Hosted",
      price: "6",
      priceCurrency: "EUR",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: "6",
        priceCurrency: "EUR",
        referenceQuantity: { "@type": "QuantitativeValue", value: "1", unitText: "active employee / month" },
      },
      description: "Per active employee, per month. Same product as Self-host — we run the infra so you don't have to.",
      availability: "https://schema.org/InStock",
      url: "https://pulsehr.it/pricing#hosted",
    },
    {
      "@type": "Offer",
      name: "Support SLA",
      price: "400",
      priceCurrency: "EUR",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: "400",
        priceCurrency: "EUR",
        referenceQuantity: { "@type": "QuantitativeValue", value: "1", unitText: "month" },
      },
      description: "Optional flat add-on for self-hosters: priority patches and guaranteed response times.",
      availability: "https://schema.org/InStock",
      url: "https://pulsehr.it/pricing#support",
    },
  ],
};

const pricingFaqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [] as Array<Record<string, unknown>>,
};

const FAQ = [
  {
    q: "What's the difference between Self-host and Hosted?",
    a: "The product. The features. The source code. None of it. Hosted is the same Pulse, running on our infrastructure with daily backups, EU data residency, and a one-line response promise from us when something breaks. You pay for the operational burden being on our side instead of yours — not for unlocked features.",
  },
  {
    q: "Why \"per active employee\" and what does active mean?",
    a: "An employee is active in a calendar month if they had a contract on any day of that month or were paid in that month. You don't pay for offboarded people after their exit date.",
  },
  {
    q: "Is there an enterprise tier with extra features?",
    a: "No. The OSS is the whole product. API, webhooks, SAML SSO, audit logs, SCIM — all in the public repo, all in every Hosted account. If a feature exists on Hosted, it exists in the self-host docker image, full stop.",
  },
  {
    q: "Does Pulse replace my HRIS or payroll system?",
    a: "No. Pulse is the people half of HR — status, growth, kudos, wellbeing. Payroll, time tracking, recruiting and project allocation belong in tools built for them. Pulse runs alongside your HRIS, not in place of it, which is also why the per-seat price is lower than a full HRIS.",
  },
  {
    q: "Discounts for non-profits, education, open-source maintainers?",
    a: "50% off Hosted for registered non-profits, accredited education institutions, and maintainers of projects with 1k+ GitHub stars. Email sales@pulsehr.it with a one-line proof. Self-host is already free — no discount needed.",
  },
  {
    q: "What about a free Hosted tier?",
    a: "There isn't one. The free path is self-host: open-source, full-featured, 90 seconds to a workspace on your own infra. We didn't want to maintain a free-tier seat cap on Hosted because it forces feature gates we don't believe in. If you can run Docker, you can run Pulse for free.",
  },
  {
    q: "Can I move between Self-host and Hosted later?",
    a: "Yes — both directions. We publish the export schema (it's just Postgres) and the migration runbook on /docs. There's no proprietary lock-in to escape. The point of open source is that leaving is always cheap.",
  },
  {
    q: "Can I get an invoice in my company's entity's country?",
    a: "Yes. We bill from our Italian entity by default; on request we invoice from our Delaware entity (US) or via EU reverse-charge VAT. Payment via card, SEPA, ACH or wire.",
  },
];

pricingFaqLd.mainEntity = FAQ.map((f) => ({
  "@type": "Question",
  name: f.q,
  acceptedAnswer: { "@type": "Answer", text: f.a },
}));

const extraLd = [offerCatalogLd, pricingFaqLd];
---

<BaseLayout {title} {description} {path} {breadcrumbs} {extraLd}>
  <Nav />
  <main id="main">
    <section class="max-w-[1280px] mx-auto px-6 pt-20 pb-10">
      <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4 inline-flex items-center gap-2">
        <Tag class="h-3 w-3" /> Pricing
      </p>
      <h1 class="font-display text-[56px] md:text-[88px] leading-[0.95] tracking-tight max-w-4xl">
        Self-host free.<br />
        Pay us to <em class="italic text-[#b4ff39]">run</em> it<span class="text-[#b4ff39]">.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-white/70 text-lg leading-relaxed">
        The OSS is the whole product. Run it on your own infra for €0 — same
        features, same source. Or pay us €6 per active employee per month and
        we'll handle the uptime, the backups, the EU residency, the migrations.
        Either way, no sales call. No enterprise tier with extra features.
      </p>
    </section>

    <section class="max-w-[1280px] mx-auto px-6 py-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {TIERS.map((t) => (
          <article class:list={[
            "rounded-2xl border p-8 flex flex-col",
            t.bg,
            t.border,
            t.featured && "iridescent-border",
          ]}>
            <div class="flex items-baseline justify-between mb-5">
              <h2 class="font-display text-2xl m-0" style={`color:${t.accent}`}>{t.name}</h2>
              {t.featured && (
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] px-2 py-0.5 rounded-full border border-[#b4ff39]/40 text-[#b4ff39]">
                  Popular
                </span>
              )}
            </div>
            <div class="mb-4">
              <span class="font-display text-5xl" style={`color:${t.accent}`}>{t.price}</span>
              <span class="text-white/50 text-sm font-mono ml-1">/ {t.unit}</span>
            </div>
            <p class="text-white/65 leading-relaxed text-[14px] mb-6 min-h-[3em]">{t.punch}</p>

            <a
              href={t.cta.href}
              class:list={[
                "group inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-md font-medium press-scale transition-colors mb-6",
                t.featured
                  ? "bg-[#b4ff39] text-[#0b0b0d] hover:bg-[#c6ff5a]"
                  : "border border-white/15 bg-white/[0.04] hover:bg-white/[0.08]",
              ]}
            >
              {t.id === "self-host" && <Github class="h-4 w-4" />}
              {t.cta.label}
              <ArrowRight class="h-4 w-4 group-hover:translate-x-0.5 transition-transform" />
            </a>

            <ul class="space-y-2 list-none p-0 m-0 mb-4">
              {t.included.map((f) => (
                <li class="flex items-start gap-2 text-sm text-white/80">
                  <Check class="h-4 w-4 mt-0.5 shrink-0" style={`color:${t.accent}`} />
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            {t.notIncluded.length > 0 && (
              <div class="mt-auto pt-4 border-t border-white/5">
                <p class="font-mono uppercase tracking-[0.2em] text-[10px] text-white/40 mb-2">Not included</p>
                <ul class="space-y-1 list-none p-0 m-0">
                  {t.notIncluded.map((f) => (
                    <li class="text-[12px] text-white/45">{f}</li>
                  ))}
                </ul>
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[1280px] mx-auto px-6 py-16">
      <div class="rounded-2xl border border-white/10 bg-[#0f0f11] p-8">
        <div class="flex items-start gap-4">
          <Server class="h-6 w-6 text-[#6fd8ff] shrink-0 mt-1" />
          <div>
            <h2 class="font-display text-2xl mb-3 m-0">What self-hosting costs you.</h2>
            <p class="text-white/70 leading-relaxed max-w-3xl mb-3">
              The software is €0. The infra under it isn't. A Pulse deployment
              for a 50-person team fits comfortably on a €20–40/month Hetzner
              box, or about $30–60/month on AWS us-east-1 (RDS + ECS + an S3
              bucket).
            </p>
            <p class="text-white/55 text-[13px] font-mono">
              Reference infra costs at <a href="https://github.com/davide97g/pulse-hr/tree/main/docs/self-host" class="text-[#6fd8ff] hover:underline">/docs/self-host</a> in the repo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-[960px] mx-auto px-6 py-16">
      <h2 class="font-display text-4xl md:text-5xl tracking-tight mb-10">
        Pricing FAQ.
      </h2>
      <div class="space-y-3">
        {FAQ.map((f) => (
          <details class="rounded-xl border border-white/10 bg-[#0f0f11] p-5 group">
            <summary class="cursor-pointer font-medium text-white list-none group-open:text-[#b4ff39] transition-colors">
              {f.q}
            </summary>
            <p class="mt-3 text-[14px] text-white/70 leading-relaxed m-0">{f.a}</p>
          </details>
        ))}
      </div>

      <div class="mt-10 rounded-2xl border border-white/10 bg-white/[0.02] p-6 flex items-start gap-3">
        <Info class="h-5 w-5 text-[#b4ff39] shrink-0 mt-0.5" />
        <p class="text-sm text-white/60 leading-relaxed m-0">
          Still have pricing questions? Ask in public on <a href="https://github.com/davide97g/pulse-hr/discussions" class="text-[#b4ff39] hover:underline">GitHub Discussions</a>, or email <a href="mailto:sales@pulsehr.it" class="text-[#b4ff39] hover:underline">sales@pulsehr.it</a>. Nothing gets routed to a funnel — real humans, real answers.
        </p>
      </div>
    </section>

    <Cta />
  </main>
  <Footer />
</BaseLayout>
