---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import LabsSection from "../components/LabsSection.astro";
import Cta from "../components/Cta.astro";
import { SITE, getLanding } from "../data/landing";
import { useI18n } from "../i18n";

const { locale, t } = useI18n(Astro);
const { LABS } = getLanding(locale);

const labsLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Pulse Labs features",
  itemListElement: LABS.map((lab, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "SoftwareApplication",
      name: lab.kind,
      applicationCategory: "BusinessApplication",
      description: lab.body,
      isPartOf: { "@id": `${SITE.url}/#software` },
    },
  })),
};
---

<BaseLayout title={t.labsPage.title} description={t.labsPage.description} path="/labs">
  <Nav />
  <main id="main">
    <section class="max-w-[1280px] mx-auto px-6 pt-20 pb-10">
      <p class="font-mono uppercase tracking-[0.25em] text-xs text-[#b4ff39] mb-4">
        {t.labsPage.eyebrow}
      </p>
      <h1 class="font-display text-[56px] md:text-[80px] leading-[0.95] tracking-tight max-w-4xl">
        {t.labsPage.titleLine1}<br />
        <em class="italic text-[#b4ff39]">{t.labsPage.titleItalic}</em>{t.labsPage.titleAfter}
      </h1>
      <p class="mt-6 max-w-2xl text-white/70 text-lg leading-relaxed">
        {t.labsPage.body}
      </p>
    </section>
    <LabsSection />
    <Cta />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(labsLd)} />
</BaseLayout>
