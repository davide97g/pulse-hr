---
import "../styles/global.css";
import { SITE, getLanding } from "../data/landing";
import { useI18n, HTML_LANG, OG_LOCALE, localizePath, LOCALES, DEFAULT_LOCALE } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  /** Path relative to site root, e.g. "/", "/pricing". Used for canonical + OG URL.
   *  Pass the locale-agnostic path — this layout prefixes it per current locale. */
  path?: string;
  ogImage?: string;
  /** Set true on the landing page so we emit extra JSON-LD (Organization + SoftwareApplication + FAQPage). */
  isHome?: boolean;
  /** Optional additional keywords; appended to SITE.keywords. */
  keywords?: string;
  /** Stub/placeholder pages set this to keep them out of the index until content lands. */
  noIndex?: boolean;
  /**
   * Breadcrumb trail (shallowest → deepest). Emitted as BreadcrumbList JSON-LD.
   * The home item is prepended automatically; pass only the steps after it.
   */
  breadcrumbs?: { name: string; path: string }[];
  /** Extra JSON-LD blocks specific to this page (Offer, Article, etc.). */
  extraLd?: Record<string, unknown>[];
}

const { locale, t } = useI18n(Astro);
const landing = getLanding(locale);

const {
  title = `${landing.site.tagline} — ${SITE.name}`,
  description = landing.site.description,
  path = "/",
  ogImage = SITE.ogImage,
  isHome = false,
  keywords,
  noIndex = false,
  breadcrumbs,
  extraLd,
} = Astro.props;

const localePath = localizePath(path, locale);
const canonical = new URL(localePath, SITE.url).toString();
const absoluteOg = new URL(ogImage, SITE.url).toString();
const allKeywords = keywords ? `${landing.site.keywords}, ${keywords}` : landing.site.keywords;

const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE.url}/#organization`,
  name: SITE.name,
  url: SITE.url,
  logo: new URL("/favicon.svg", SITE.url).toString(),
  sameAs: [
    "https://twitter.com/pulsehr",
    "https://www.linkedin.com/company/pulse-hr",
    "https://github.com/pulsehr",
  ],
};

const softwareLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": `${SITE.url}/#software`,
  name: SITE.name,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, iOS, Android, macOS, Windows",
  description,
  url: SITE.url,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description:
      locale === "it"
        ? "Gratis per i primi 5 dipendenti, per sempre."
        : "Free for the first 5 employees, forever.",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "312",
  },
  review: landing.TESTIMONIALS.map((tt) => ({
    "@type": "Review",
    reviewBody: tt.body,
    reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
    author: { "@type": "Person", name: tt.who, jobTitle: tt.role },
  })),
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["#hero-title", "#faq summary h3"],
  },
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: landing.FAQ.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbLd = breadcrumbs && breadcrumbs.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: new URL(localizePath("/", locale), SITE.url).toString(),
        },
        ...breadcrumbs.map((b, i) => ({
          "@type": "ListItem",
          position: i + 2,
          name: b.name,
          item: new URL(localizePath(b.path, locale), SITE.url).toString(),
        })),
      ],
    }
  : null;

const teamLd = {
  "@context": "https://schema.org",
  "@graph": landing.TEAM.map((m) => ({
    "@type": "Person",
    name: m.n,
    jobTitle: m.r,
    description: m.bio,
    worksFor: { "@id": `${SITE.url}/#organization` },
    sameAs: [
      `https://www.linkedin.com/in/${m.n.toLowerCase().replace(/\s+/g, "-")}`,
    ],
  })),
};

// hreflang alternates for SEO — every page exposes all locales.
const alternates = LOCALES.map((l) => ({
  lang: HTML_LANG[l],
  href: new URL(localizePath(path, l), SITE.url).toString(),
}));
---

<!doctype html>
<html lang={HTML_LANG[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0b0d" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={allKeywords} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath(path, DEFAULT_LOCALE), SITE.url).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={OG_LOCALE[locale]} />
    {LOCALES.filter((l) => l !== locale).map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALE[l]} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOg} />

    <!-- Robots -->
    {noIndex ? (
      <meta name="robots" content="noindex,nofollow" />
    ) : (
      <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    )}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />}
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(teamLd)} />}
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
    {extraLd?.map((block) => <script type="application/ld+json" set:html={JSON.stringify(block)} />)}

    <!-- Agent discovery -->
    <link rel="api-catalog" href="/.well-known/api-catalog" type="application/linkset+json" />
    <link rel="agent-skills" href="/.well-known/agent-skills/index.json" type="application/json" />
    <link rel="mcp-server-card" href="/.well-known/mcp/server-card.json" type="application/json" />

    <!-- Browser locale auto-detect.
         Stored preference (from LangSwitcher) always wins. Otherwise on first visit
         we pick a locale from navigator.languages and redirect once. -->
    <script is:inline define:vars={{ currentLocale: locale }}>
      (function () {
        try {
          var KEY = "pulse.locale";
          var SUPPORTED = ["en", "it"];
          var pathname = location.pathname;
          function targetFor(lang) {
            if (lang === "en") {
              return pathname.replace(/^\/it(\/|$)/, "/");
            }
            if (pathname.indexOf("/it") === 0) return pathname;
            return "/it" + (pathname === "/" ? "" : pathname);
          }
          var stored = null;
          try { stored = localStorage.getItem(KEY); } catch (e) {}
          if (stored && SUPPORTED.indexOf(stored) !== -1) {
            if (stored !== currentLocale) {
              var t = targetFor(stored);
              if (t !== pathname) location.replace(t + location.search + location.hash);
            }
            return;
          }
          var redirected = false;
          try { redirected = sessionStorage.getItem("pulse.locale.autoredirected") === "1"; } catch (e) {}
          if (redirected) return;
          var navLangs = (navigator.languages && navigator.languages.length)
            ? navigator.languages : [navigator.language || "en"];
          var detected = "en";
          for (var i = 0; i < navLangs.length; i++) {
            var lc = (navLangs[i] || "").toLowerCase();
            if (lc.indexOf("it") === 0) { detected = "it"; break; }
            if (lc.indexOf("en") === 0) { detected = "en"; break; }
          }
          if (detected === currentLocale) return;
          try { sessionStorage.setItem("pulse.locale.autoredirected", "1"); } catch (e) {}
          var t = targetFor(detected);
          if (t && t !== pathname) location.replace(t + location.search + location.hash);
        } catch (e) {}
      })();
    </script>

    <!-- WebMCP: expose site actions to AI agents via navigator.modelContext. -->
    <script>
      if (typeof navigator !== "undefined" && "modelContext" in navigator) {
        try {
          navigator.modelContext.provideContext({
            tools: [
              {
                name: "view_pricing",
                description: "Navigate to the Pulse HR pricing page.",
                inputSchema: { type: "object", properties: {} },
                execute: () => { window.location.href = "/pricing"; },
              },
              {
                name: "request_demo",
                description: "Open the Pulse HR contact / demo request form.",
                inputSchema: { type: "object", properties: {} },
                execute: () => { window.location.href = "/contact"; },
              },
              {
                name: "browse_docs",
                description: "Navigate to the Pulse HR product documentation.",
                inputSchema: {
                  type: "object",
                  properties: { topic: { type: "string", description: "Optional topic slug" } },
                },
                execute: ({ topic }) => {
                  window.location.href = topic ? `/docs/${encodeURIComponent(topic)}` : "/docs";
                },
              },
              {
                name: "open_changelog",
                description: "Navigate to the Pulse HR changelog.",
                inputSchema: { type: "object", properties: {} },
                execute: () => { window.location.href = "/changelog"; },
              },
              {
                name: "open_sandbox",
                description: "Open the product sandbox sign-up at app.pulsehr.it.",
                inputSchema: { type: "object", properties: {} },
                execute: () => { window.location.href = "https://app.pulsehr.it/signup"; },
              },
            ],
          });
        } catch (err) {
          console.warn("WebMCP registration failed", err);
        }
      }
    </script>
  </head>
  <body class="min-h-screen bg-[#0b0b0d] text-[#f2f2ee] overflow-x-hidden">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-[#b4ff39] focus:text-[#0b0b0d] focus:px-3 focus:py-1.5 focus:rounded-md"
    >
      {t.a11y.skipToMain}
    </a>
    <slot />
  </body>
</html>
