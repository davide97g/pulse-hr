{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"getting-started\",\"time-tracking\",\"clients-projects\",\"recruiting\",\"labs-highlights\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0"
  },
  "setup": "{{SETUP_TRAILER}}",
  "steps": [
    {
      "action": "wait",
      "ms": 800,
      "waitFor": "button:has-text('WORKLOAD')",
      "timeout": 12000
    },
    {
      "action": "screenshot",
      "name": "01-constellation-idle",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 1400
    },
    {
      "action": "zoom",
      "selector": "button:has-text('WORKLOAD')",
      "scale": 1.55,
      "duration": 320
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "click",
      "selector": "button:has-text('SENTIMENT')",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "click",
      "selector": "button:has-text('PRESENCE')",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "click",
      "selector": "button:has-text('WORKLOAD')",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 1100
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 280
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "screenshot",
      "name": "02-constellation-final",
      "pauseAfter": 80
    }
  ]
}
