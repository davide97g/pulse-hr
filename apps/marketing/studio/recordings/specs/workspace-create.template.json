{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/login",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1"
  },
  "steps": [
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "zoom",
      "selector": "input[type=email]",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "type",
      "selector": "input[type=email]",
      "text": "{{TEST_EMAIL}}",
      "delay": 12
    },
    {
      "action": "wait",
      "ms": 400,
      "waitFor": "input[type=password]",
      "timeout": 15000
    },
    {
      "action": "zoom",
      "selector": "input[type=password]",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "type",
      "selector": "input[type=password]",
      "text": "{{TEST_PASSWORD}}",
      "delay": 12
    },
    {
      "action": "click",
      "selector": "button[type=submit]",
      "zoom": 1.8
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 80
    },
    {
      "action": "wait",
      "ms": 1200,
      "waitFor": "#welcome-cta",
      "timeout": 15000
    },
    {
      "action": "screenshot",
      "name": "01-welcome-editorial-hero"
    },
    {
      "action": "scroll",
      "y": 600,
      "speed": 1,
      "pauseAfter": 400
    },
    {
      "action": "screenshot",
      "name": "02-welcome-editorial-cta"
    },
    {
      "action": "zoom",
      "selector": "#welcome-cta",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "wait",
      "ms": 250
    },
    {
      "action": "click",
      "selector": "#welcome-cta"
    },
    {
      "action": "wait",
      "ms": 200,
      "waitFor": "#ws-name",
      "timeout": 10000
    },
    {
      "action": "screenshot",
      "name": "02-workspace-name-step"
    },
    {
      "action": "zoom",
      "selector": "#ws-name",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "fill",
      "selector": "#ws-name",
      "text": ""
    },
    {
      "action": "type",
      "selector": "#ws-name",
      "text": "Pulse HR",
      "delay": 18
    },
    {
      "action": "screenshot",
      "name": "03-workspace-name-filled"
    },
    {
      "action": "zoom",
      "selector": "[role=dialog] >> button:has-text('Continue')",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "click",
      "selector": "[role=dialog] >> button:has-text('Continue')"
    },
    {
      "action": "wait",
      "ms": 400,
      "waitFor": "#size-large",
      "timeout": 10000
    },
    {
      "action": "screenshot",
      "name": "04-company-size-step"
    },
    {
      "action": "zoom",
      "selector": "#size-large",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "click",
      "selector": "#size-large"
    },
    {
      "action": "screenshot",
      "name": "05-company-size-selected"
    },
    {
      "action": "zoom",
      "selector": "[role=dialog] >> button:has-text('Continue')",
      "scale": 1.8,
      "duration": 120
    },
    {
      "action": "click",
      "selector": "[role=dialog] >> button:has-text('Continue')"
    },
    {
      "action": "wait",
      "ms": 350,
      "waitFor": "#teammate-0-name",
      "timeout": 10000
    },
    {
      "action": "screenshot",
      "name": "06-teammates-optional"
    },
    {
      "action": "zoom",
      "selector": "#teammate-0-name",
      "scale": 1.6,
      "duration": 180
    },
    {
      "action": "type",
      "selector": "#teammate-0-name",
      "text": "John Doe",
      "delay": 14
    },
    {
      "action": "wait",
      "ms": 80
    },
    {
      "action": "type",
      "selector": "#teammate-1-name",
      "text": "Jane Smith",
      "delay": 14
    },
    {
      "action": "wait",
      "ms": 80
    },
    {
      "action": "zoom",
      "selector": "#teammate-2-name",
      "scale": 1.6,
      "duration": 180
    },
    {
      "action": "type",
      "selector": "#teammate-2-name",
      "text": "Jim Beam",
      "delay": 14
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "screenshot",
      "name": "07-teammates-filled"
    },
    {
      "action": "click",
      "selector": "button:has-text('Create workspace')",
      "zoom": 1.8
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 80
    },
    {
      "action": "wait",
      "ms": 1000
    },
    {
      "action": "screenshot",
      "name": "08-dashboard-ready"
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 120
    }
  ]
}
