{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/skills/me",
  "colorScheme": "dark",
  "viewport": { "width": 1280, "height": 720 },
  "outputSize": { "width": 1920, "height": 1080 },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 280
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"getting-started\",\"time-tracking\",\"clients-projects\",\"recruiting\",\"labs-highlights\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0",
    "pulse.changelog.skip": "1"
  },
  "setup": "{{SETUP_TRAILER}}",
  "steps": [
    { "action": "wait", "ms": 900, "waitFor": "button:has-text('Constellation')", "timeout": 12000 },
    { "action": "zoom", "selector": "[role=tablist][aria-label='Skills view']", "scale": 1.45, "duration": 280 },
    { "action": "wait", "ms": 700 },
    { "action": "zoom", "scale": 1, "duration": 220 },
    { "action": "wait", "ms": 1100 },
    { "action": "zoom", "selector": "button:has-text('Constellation')", "scale": 1.4, "duration": 280 },
    { "action": "wait", "ms": 900 },
    { "action": "zoom", "scale": 1, "duration": 220 },
    { "action": "wait", "ms": 700 },
    { "action": "click", "selector": "button:has-text('Index')", "pauseAfter": 80 },
    { "action": "wait", "ms": 900 },
    { "action": "scroll", "y": 280, "pauseAfter": 220 },
    { "action": "wait", "ms": 700 },
    { "action": "scroll", "y": 0, "pauseAfter": 220 },
    { "action": "wait", "ms": 500 },
    { "action": "click", "selector": "button:has-text('Manifesto')", "pauseAfter": 80 },
    { "action": "wait", "ms": 1000 },
    { "action": "scroll", "y": 220, "pauseAfter": 220 },
    { "action": "wait", "ms": 700 },
    { "action": "scroll", "y": 0, "pauseAfter": 220 },
    { "action": "wait", "ms": 500 },
    { "action": "click", "selector": "button:has-text('Constellation')", "pauseAfter": 80 },
    { "action": "wait", "ms": 1100 },
    { "action": "zoom", "scale": 1.3, "duration": 280 },
    { "action": "wait", "ms": 800 },
    { "action": "zoom", "scale": 1, "duration": 220 },
    { "action": "wait", "ms": 600 }
  ]
}
