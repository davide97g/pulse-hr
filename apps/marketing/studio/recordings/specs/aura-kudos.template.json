{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/growth?tab=kudos",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"getting-started\",\"time-tracking\",\"clients-projects\",\"recruiting\",\"labs-highlights\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0"
  },
  "setup": "{{SETUP_AURA}}",
  "steps": [
    {
      "action": "navigate",
      "url": "{{BASE_URL}}/growth?tab=kudos"
    },
    {
      "action": "wait",
      "ms": 800,
      "waitFor": "text=Send kudos",
      "timeout": 12000
    },
    {
      "action": "screenshot",
      "name": "01-kudos-idle",
      "pauseAfter": 80
    },
    {
      "action": "click",
      "selector": "button[role='combobox']",
      "timeout": 8000,
      "pauseAfter": 120,
      "zoom": 1.8
    },
    {
      "action": "wait",
      "ms": 220
    },
    {
      "action": "click",
      "selector": "[role='option']:has-text('Marcus Rivera')",
      "timeout": 8000,
      "pauseAfter": 120,
      "zoom": 1.8
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "click",
      "selector": "button:has-text('Send 25 coins')",
      "timeout": 8000,
      "pauseAfter": 120,
      "zoom": 2
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 180
    },
    {
      "action": "screenshot",
      "name": "02-kudos-sent",
      "pauseAfter": 80
    }
  ]
}
