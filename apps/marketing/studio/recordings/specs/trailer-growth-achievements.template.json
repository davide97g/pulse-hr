{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/growth?tab=achievements",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"getting-started\",\"time-tracking\",\"clients-projects\",\"recruiting\",\"labs-highlights\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0"
  },
  "setup": "{{SETUP_TRAILER}}",
  "steps": [
    {
      "action": "wait",
      "ms": 700,
      "waitFor": "button:has-text('CRAFT')",
      "timeout": 12000
    },
    {
      "action": "screenshot",
      "name": "01-achievements-all",
      "pauseAfter": 80
    },
    {
      "action": "zoom",
      "selector": "button:has-text('CRAFT')",
      "scale": 1.5,
      "duration": 360
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "click",
      "selector": "button:has-text('CRAFT')",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "click",
      "selector": "button:has-text('LEADERSHIP')",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "click",
      "selector": "button:has-text('IMPATTO')",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "click",
      "selector": "button:has-text('TUTTI')",
      "pauseAfter": 80
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 260
    },
    {
      "action": "wait",
      "ms": 600
    },
    {
      "action": "screenshot",
      "name": "02-achievements-final",
      "pauseAfter": 80
    }
  ]
}
