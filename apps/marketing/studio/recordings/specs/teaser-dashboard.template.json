{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 280
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"getting-started\",\"time-tracking\",\"clients-projects\",\"recruiting\",\"labs-highlights\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0",
    "pulse.changelog.skip": "1"
  },
  "setup": "{{SETUP_TRAILER}}",
  "steps": [
    {
      "action": "wait",
      "ms": 700,
      "waitFor": "button:has-text('WORKLOAD')",
      "timeout": 12000
    },
    {
      "action": "zoom",
      "selector": "button:has-text('WORKLOAD')",
      "scale": 1.5,
      "duration": 260
    },
    {
      "action": "wait",
      "ms": 500
    },
    {
      "action": "click",
      "selector": "button:has-text('SENTIMENT')",
      "pauseAfter": 60
    },
    {
      "action": "wait",
      "ms": 450
    },
    {
      "action": "click",
      "selector": "button:has-text('PRESENCE')",
      "pauseAfter": 60
    },
    {
      "action": "wait",
      "ms": 450
    },
    {
      "action": "click",
      "selector": "button:has-text('WORKLOAD')",
      "pauseAfter": 60
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 220
    },
    {
      "action": "wait",
      "ms": 350
    },
    {
      "action": "click",
      "selector": "button:has-text('ENG')",
      "pauseAfter": 60
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "click",
      "selector": "button:has-text('OPS')",
      "pauseAfter": 60
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "click",
      "selector": "button:has-text('DESIGN')",
      "pauseAfter": 60
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "click",
      "selector": "button:has-text('ALL')",
      "pauseAfter": 60
    },
    {
      "action": "wait",
      "ms": 700
    }
  ]
}
