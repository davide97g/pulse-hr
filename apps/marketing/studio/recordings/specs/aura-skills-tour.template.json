{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/skills/me",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 240
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0"
  },
  "setup": "{{SETUP_AURA}}",
  "steps": [
    {
      "action": "navigate",
      "url": "{{BASE_URL}}/skills/me"
    },
    {
      "action": "wait",
      "ms": 700,
      "waitFor": "[role=tablist][aria-label='Skills view']",
      "timeout": 12000
    },
    { "action": "wait", "ms": 350 },
    {
      "action": "zoom",
      "scale": 1.35,
      "duration": 260
    },
    { "action": "wait", "ms": 600 },
    { "action": "zoom", "scale": 1, "duration": 200 },
    { "action": "wait", "ms": 200 },
    {
      "action": "zoom",
      "selector": "[role=tablist][aria-label='Skills view'] >> [role=tab]:has-text('Team')",
      "scale": 1.5,
      "duration": 220
    },
    {
      "action": "click",
      "selector": "[role=tablist][aria-label='Skills view'] >> [role=tab]:has-text('Team')"
    },
    {
      "action": "wait",
      "ms": 450,
      "waitFor": "text=PEOPLE × SKILLS",
      "timeout": 10000
    },
    { "action": "wait", "ms": 200 },
    {
      "action": "zoom",
      "selector": "text=PEOPLE × SKILLS",
      "scale": 1.25,
      "duration": 500
    },
    { "action": "wait", "ms": 1800 },
    {
      "action": "hover",
      "selector": ".hover\\:scale-110 >> nth=3",
      "pauseAfter": 2000
    },
    { "action": "wait", "ms": 500 },
    { "action": "zoom", "scale": 1, "duration": 220 },
    { "action": "wait", "ms": 250 }
  ]
}
