{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 280
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0"
  },
  "setup": "{{SETUP_AURA}}",
  "steps": [
    {
      "action": "wait",
      "ms": 700,
      "waitFor": "button:has-text('WORKLOAD')",
      "timeout": 12000
    },
    { "action": "wait", "ms": 900 },
    {
      "action": "zoom",
      "selector": "button:has-text('WORKLOAD')",
      "scale": 1.45,
      "duration": 280
    },
    { "action": "wait", "ms": 600 },
    {
      "action": "hover",
      "selector": "path.hex-spawn:nth-of-type(4)",
      "pauseAfter": 360
    },
    { "action": "wait", "ms": 900 },
    {
      "action": "hover",
      "selector": "path.hex-spawn:nth-of-type(9)",
      "pauseAfter": 360
    },
    { "action": "wait", "ms": 800 },
    {
      "action": "zoom",
      "selector": "path.hex-spawn:nth-of-type(9)",
      "scale": 1.9,
      "duration": 320
    },
    { "action": "wait", "ms": 900 },
    { "action": "zoom", "scale": 1, "duration": 220 },
    { "action": "wait", "ms": 400 }
  ]
}
