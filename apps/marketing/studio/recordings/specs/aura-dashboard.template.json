{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0"
  },
  "setup": "{{SETUP_AURA}}",
  "steps": [
    {
      "action": "wait",
      "ms": 900,
      "waitFor": "main",
      "timeout": 12000
    },
    { "action": "wait", "ms": 2200 },
    {
      "action": "zoom",
      "scale": 1.35,
      "duration": 900
    },
    { "action": "wait", "ms": 3200 },
    {
      "action": "scroll",
      "y": 220,
      "speed": 0.6,
      "pauseAfter": 600
    },
    { "action": "wait", "ms": 1400 },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 600
    },
    { "action": "wait", "ms": 700 }
  ]
}
