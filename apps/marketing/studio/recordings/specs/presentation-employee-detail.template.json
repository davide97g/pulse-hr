{
  "$schema": "../../../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/people",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 240
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1",
    "pulse.locale": "en",
    "pulse.demoBanner.dismissed.v1": "1",
    "pulse.lastSeenVersion": "0.9.0"
  },
  "setup": "{{SETUP_AURA}}",
  "steps": [
    {
      "action": "navigate",
      "url": "{{BASE_URL}}/people"
    },
    {
      "action": "wait",
      "ms": 900,
      "waitFor": "main",
      "timeout": 12000
    },
    { "action": "wait", "ms": 600 },
    {
      "action": "zoom",
      "scale": 1.3,
      "duration": 320
    },
    { "action": "wait", "ms": 900 },
    {
      "action": "scroll",
      "y": 220,
      "speed": 0.5,
      "pauseAfter": 600
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 220
    },
    {
      "action": "scroll",
      "y": -220,
      "speed": 0.5,
      "pauseAfter": 400
    },
    {
      "action": "click",
      "selector": "main a[href*='/people/']:not([href$='/people/new']):not([href$='/people'])",
      "zoom": 1.5,
      "pauseAfter": 600
    },
    {
      "action": "wait",
      "ms": 900,
      "waitFor": "main",
      "timeout": 8000
    },
    {
      "action": "zoom",
      "scale": 1.15,
      "duration": 280
    },
    { "action": "wait", "ms": 1200 },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 200
    },
    { "action": "wait", "ms": 400 }
  ]
}
