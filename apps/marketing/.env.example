# Google Analytics 4 (production only; set in Vercel, leave empty for local)
PUBLIC_GA_MEASUREMENT_ID=

# OpenAI — used by studio/scripts/generate-vo.ts to synthesise the
# presentation narration via the gpt-4o-mini-tts endpoint. Studio-only.
OPENAI_API_KEY=sk-proj-1234567890
# Optional overrides (default voice is "onyx" — deep, confident):
# OPENAI_TTS_VOICE=onyx   # onyx | ash | sage | alloy | verse | echo | shimmer
# OPENAI_TTS_MODEL=gpt-4o-mini-tts