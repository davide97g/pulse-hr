{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/",
  "colorScheme": "dark",
  "viewport": { "width": 1280, "height": 720 },
  "outputSize": { "width": 1920, "height": 1080 },
  "chrome": { "url": true },
  "background": {
    "gradient": { "from": "#667eea", "to": "#764ba2" },
    "borderRadius": 12
  },
  "cursor": true,
  "localStorage": {
    "pulse.theme": "employee",
    "pulse.tours.completed": "[]"
  },
  "setup": {
    "url": "{{BASE_URL}}/login",
    "steps": [
      { "action": "wait", "ms": 200 },
      { "action": "zoom", "selector": "input[type=email]", "scale": 1.8, "duration": 180 },
      { "action": "type", "selector": "input[type=email]", "text": "{{TEST_EMAIL}}", "delay": 12 },
      { "action": "zoom", "selector": "input[type=password]", "scale": 1.8, "duration": 180 },
      {
        "action": "type",
        "selector": "input[type=password]",
        "text": "{{TEST_PASSWORD}}",
        "delay": 12
      },
      { "action": "zoom", "selector": "button[type=submit]", "scale": 1.8, "duration": 180 },
      { "action": "click", "selector": "button[type=submit]" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 1600 },

      { "action": "zoom", "selector": "button:has-text('Admin')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Admin')" },
      { "action": "wait", "ms": 150 },
      { "action": "zoom", "selector": "button:has-text('Continue')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Continue')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 200 },

      {
        "action": "zoom",
        "selector": "button:has-text('Hire faster')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Hire faster')" },
      { "action": "wait", "ms": 120 },
      {
        "action": "zoom",
        "selector": "button:has-text('Retain top talent')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Retain top talent')" },
      { "action": "wait", "ms": 120 },
      {
        "action": "zoom",
        "selector": "button:has-text('Boost engagement')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Boost engagement')" },
      { "action": "wait", "ms": 120 },
      { "action": "zoom", "selector": "button:has-text('Continue')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Continue')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 200 },

      { "action": "zoom", "selector": "#ws-name", "scale": 1.8, "duration": 180 },
      { "action": "fill", "selector": "#ws-name", "text": "" },
      { "action": "type", "selector": "#ws-name", "text": "Bitrock", "delay": 18 },
      { "action": "wait", "ms": 150 },
      { "action": "zoom", "selector": "button:has-text('Continue')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Continue')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 200 },

      { "action": "zoom", "selector": "#col-0", "scale": 1.6, "duration": 180 },
      { "action": "type", "selector": "#col-0", "text": "Niccolò Naso", "delay": 14 },
      { "action": "wait", "ms": 80 },
      { "action": "type", "selector": "#col-1", "text": "Yi Zhang", "delay": 14 },
      { "action": "wait", "ms": 80 },
      { "action": "type", "selector": "#col-2", "text": "Andrea Mazza", "delay": 14 },
      { "action": "wait", "ms": 200 },
      {
        "action": "zoom",
        "selector": "button:has-text('Create workspace')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Create workspace')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 1600 },
      { "action": "wait", "ms": 400, "waitFor": "main", "timeout": 10000 }
    ]
  },
  "steps": [
    { "action": "wait", "ms": 250, "waitFor": "main", "timeout": 10000 },

    { "action": "zoom", "selector": "[data-tour=\"sidebar-help\"]", "scale": 2, "duration": 130 },
    {
      "action": "click",
      "selector": "[data-tour=\"sidebar-help\"]",
      "timeout": 8000,
      "pauseAfter": 120
    },
    { "action": "wait", "ms": 220 },
    { "action": "screenshot", "name": "01-help-tours-menu", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=menu] [role=menuitem]:has-text('Welcome to Pulse HR')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=menu] [role=menuitem]:has-text('Welcome to Pulse HR')",
      "timeout": 8000,
      "pauseAfter": 120
    },
    { "action": "wait", "ms": 420 },
    { "action": "screenshot", "name": "02-tour-intro-welcome", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=dialog] button:has-text('Next')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=dialog] button:has-text('Next')",
      "timeout": 8000,
      "pauseAfter": 100
    },
    { "action": "wait", "ms": 520 },
    { "action": "screenshot", "name": "03-tour-sidebar-nav", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=dialog] button:has-text('Next')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=dialog] button:has-text('Next')",
      "timeout": 8000,
      "pauseAfter": 100
    },
    { "action": "wait", "ms": 440 },
    { "action": "screenshot", "name": "04-tour-global-search", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=dialog] button:has-text('Next')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=dialog] button:has-text('Next')",
      "timeout": 8000,
      "pauseAfter": 100
    },
    { "action": "wait", "ms": 360 },
    { "action": "screenshot", "name": "05-tour-status-log", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=dialog] button:has-text('Next')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=dialog] button:has-text('Next')",
      "timeout": 8000,
      "pauseAfter": 100
    },
    { "action": "wait", "ms": 300 },
    { "action": "screenshot", "name": "06-tour-quick-actions", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=dialog] button:has-text('Next')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=dialog] button:has-text('Next')",
      "timeout": 8000,
      "pauseAfter": 100
    },
    { "action": "wait", "ms": 240 },
    { "action": "screenshot", "name": "07-tour-notifications", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=dialog] button:has-text('Next')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=dialog] button:has-text('Next')",
      "timeout": 8000,
      "pauseAfter": 100
    },
    { "action": "wait", "ms": 200 },
    { "action": "screenshot", "name": "08-tour-youre-set", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "[role=dialog] button:has-text('Finish')",
      "scale": 1.85,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "[role=dialog] button:has-text('Finish')",
      "timeout": 8000,
      "pauseAfter": 120
    },
    { "action": "wait", "ms": 320 },
    { "action": "screenshot", "name": "09-dashboard-after-tour", "pauseAfter": 80 },
    { "action": "zoom", "scale": 1, "duration": 100 }
  ]
}
