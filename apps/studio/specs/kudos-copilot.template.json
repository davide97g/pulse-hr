{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/login",
  "viewport": {
    "width": 1440,
    "height": 900
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "steps": [
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "screenshot",
      "name": "01-login"
    },
    {
      "action": "type",
      "selector": "input[type=email]",
      "text": "{{TEST_EMAIL}}",
      "delay": 40
    },
    {
      "action": "wait",
      "ms": 400,
      "waitFor": "input[type=password]",
      "timeout": 15000
    },
    {
      "action": "wait",
      "ms": 250
    },
    {
      "action": "type",
      "selector": "input[type=password]",
      "text": "{{TEST_PASSWORD}}",
      "delay": 40
    },
    {
      "action": "wait",
      "ms": 500
    },
    {
      "action": "click",
      "selector": "button[type=submit]",
      "zoom": 1.4
    },
    {
      "action": "wait",
      "ms": 3500
    },
    {
      "action": "screenshot",
      "name": "02-welcome"
    },
    {
      "action": "fill",
      "selector": "#workspace-name",
      "text": ""
    },
    {
      "action": "type",
      "selector": "#workspace-name",
      "text": "Acme",
      "delay": 60
    },
    {
      "action": "wait",
      "ms": 500
    },
    {
      "action": "click",
      "selector": "button:has-text('Create my workspace')",
      "zoom": 1.5
    },
    {
      "action": "wait",
      "ms": 2500
    },
    {
      "action": "screenshot",
      "name": "03-dashboard"
    },
    {
      "action": "keyboard",
      "key": "Meta+k"
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "zoom",
      "selector": "[role=dialog]",
      "scale": 1.3,
      "duration": 700
    },
    {
      "action": "type",
      "selector": "[role=dialog] input",
      "text": "4h migration yesterday",
      "delay": 55
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "screenshot",
      "name": "04-copilot-intent"
    },
    {
      "action": "keyboard",
      "key": "Enter"
    },
    {
      "action": "wait",
      "ms": 2200
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 500
    },
    {
      "action": "navigate",
      "url": "{{BASE_URL}}/kudos"
    },
    {
      "action": "wait",
      "ms": 1400
    },
    {
      "action": "click",
      "selector": "button:has-text('Craft')",
      "zoom": 1.6
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "click",
      "selector": "button:has-text('50')",
      "zoom": 1.6
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "fill",
      "selector": "textarea[maxlength='200']",
      "text": "Shipping the migration a week early was wild. Thank you."
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "screenshot",
      "name": "05-kudos-composed"
    },
    {
      "action": "click",
      "selector": "button:has-text('Send')",
      "zoom": 1.8
    },
    {
      "action": "wait",
      "ms": 2800
    },
    {
      "action": "screenshot",
      "name": "06-kudos-sent"
    }
  ],
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1"
  }
}
