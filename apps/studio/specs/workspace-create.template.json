{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/login",
  "colorScheme": "dark",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "outputSize": {
    "width": 1920,
    "height": 1080
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "localStorage": {
    "pulse.theme": "employee",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1"
  },
  "steps": [
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "zoom",
      "selector": "input[type=email]",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "type",
      "selector": "input[type=email]",
      "text": "{{TEST_EMAIL}}",
      "delay": 12
    },
    {
      "action": "wait",
      "ms": 400,
      "waitFor": "input[type=password]",
      "timeout": 15000
    },
    {
      "action": "zoom",
      "selector": "input[type=password]",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "type",
      "selector": "input[type=password]",
      "text": "{{TEST_PASSWORD}}",
      "delay": 12
    },
    {
      "action": "click",
      "selector": "button[type=submit]",
      "zoom": 1.8
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 80
    },
    {
      "action": "wait",
      "ms": 1600
    },
    {
      "action": "screenshot",
      "name": "01-welcome-pick-role"
    },
    {
      "action": "click",
      "selector": "button:has-text('Admin')",
      "zoom": 2
    },
    {
      "action": "wait",
      "ms": 150
    },
    {
      "action": "click",
      "selector": "button:has-text('Continue')",
      "zoom": 2
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 80
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "screenshot",
      "name": "02-goals-pick-one-or-more"
    },
    {
      "action": "click",
      "selector": "button:has-text('Hire faster')",
      "zoom": 2
    },
    {
      "action": "wait",
      "ms": 120
    },
    {
      "action": "click",
      "selector": "button:has-text('Retain top talent')",
      "zoom": 2
    },
    {
      "action": "wait",
      "ms": 120
    },
    {
      "action": "click",
      "selector": "button:has-text('Boost engagement')",
      "zoom": 2
    },
    {
      "action": "wait",
      "ms": 120
    },
    {
      "action": "click",
      "selector": "button:has-text('Continue')",
      "zoom": 2
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 80
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "screenshot",
      "name": "03-workspace-name-step"
    },
    {
      "action": "zoom",
      "selector": "#ws-name",
      "scale": 1.8,
      "duration": 180
    },
    {
      "action": "fill",
      "selector": "#ws-name",
      "text": ""
    },
    {
      "action": "type",
      "selector": "#ws-name",
      "text": "Bitrock",
      "delay": 18
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "screenshot",
      "name": "04-workspace-name-filled"
    },
    {
      "action": "click",
      "selector": "button:has-text('Continue')",
      "zoom": 2
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 80
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "screenshot",
      "name": "05-teammates-optional"
    },
    {
      "action": "zoom",
      "selector": "#col-0",
      "scale": 1.6,
      "duration": 180
    },
    {
      "action": "type",
      "selector": "#col-0",
      "text": "Niccolò Naso",
      "delay": 14
    },
    {
      "action": "wait",
      "ms": 80
    },
    {
      "action": "type",
      "selector": "#col-1",
      "text": "Yi Zhang",
      "delay": 14
    },
    {
      "action": "wait",
      "ms": 80
    },
    {
      "action": "type",
      "selector": "#col-2",
      "text": "Andrea Mazza",
      "delay": 14
    },
    {
      "action": "wait",
      "ms": 200
    },
    {
      "action": "click",
      "selector": "button:has-text('Create workspace')",
      "zoom": 2
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 80
    },
    {
      "action": "wait",
      "ms": 1600
    },
    {
      "action": "wait",
      "ms": 250
    },
    {
      "action": "screenshot",
      "name": "06-dashboard-ready"
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 120
    }
  ]
}
