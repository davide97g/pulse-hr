{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/login",
  "viewport": {
    "width": 1440,
    "height": 900
  },
  "colorScheme": "dark",
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "localStorage": {
    "pulse.theme": "dark",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1"
  },
  "steps": [
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "zoom",
      "selector": "input[type=email]",
      "scale": 1.8,
      "duration": 300
    },
    {
      "action": "type",
      "selector": "input[type=email]",
      "text": "{{TEST_EMAIL}}",
      "delay": 22
    },
    {
      "action": "wait",
      "ms": 400,
      "waitFor": "input[type=password]",
      "timeout": 15000
    },
    {
      "action": "zoom",
      "selector": "input[type=password]",
      "scale": 1.8,
      "duration": 300
    },
    {
      "action": "type",
      "selector": "input[type=password]",
      "text": "{{TEST_PASSWORD}}",
      "delay": 22
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 200
    },
    {
      "action": "click",
      "selector": "button[type=submit]",
      "zoom": 2.2
    },
    {
      "action": "wait",
      "ms": 2000
    },
    {
      "action": "zoom",
      "selector": "#workspace-name",
      "scale": 2,
      "duration": 300
    },
    {
      "action": "fill",
      "selector": "#workspace-name",
      "text": ""
    },
    {
      "action": "type",
      "selector": "#workspace-name",
      "text": "Acme",
      "delay": 30
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 200
    },
    {
      "action": "click",
      "selector": "button:has-text('Create my workspace')",
      "zoom": 2.2
    },
    {
      "action": "wait",
      "ms": 1600
    },
    {
      "action": "screenshot",
      "name": "01-dashboard"
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "navigate",
      "url": "{{BASE_URL}}/people"
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "screenshot",
      "name": "02-employees"
    },
    {
      "action": "click",
      "selector": ".cursor-pointer:has-text('Marcus Rivera'), [role=row]:has-text('Marcus Rivera')",
      "zoom": 2
    },
    {
      "action": "wait",
      "ms": 1000
    },
    {
      "action": "screenshot",
      "name": "03-employee-panel"
    },
    {
      "action": "keyboard",
      "key": "Escape"
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "navigate",
      "url": "{{BASE_URL}}/time"
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "screenshot",
      "name": "04-time"
    },
    {
      "action": "click",
      "selector": "main button:has-text('New entry') >> nth=0",
      "zoom": 2.1
    },
    {
      "action": "wait",
      "ms": 1200
    },
    {
      "action": "screenshot",
      "name": "05-new-entry-panel"
    },
    {
      "action": "click",
      "selector": "button:has-text('4h')",
      "zoom": 1.8
    },
    {
      "action": "wait",
      "ms": 300
    },
    {
      "action": "zoom",
      "selector": "textarea[placeholder='What did you work on?']",
      "scale": 1.9,
      "duration": 350
    },
    {
      "action": "type",
      "selector": "textarea[placeholder='What did you work on?']",
      "text": "Migration cutover + smoke tests",
      "delay": 28
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 250
    },
    {
      "action": "click",
      "selector": "button:has-text('Add entry')",
      "zoom": 2.2
    },
    {
      "action": "wait",
      "ms": 1800
    },
    {
      "action": "screenshot",
      "name": "06-entry-added"
    }
  ]
}
