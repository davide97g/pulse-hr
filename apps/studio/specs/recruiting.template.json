{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/recruiting",
  "viewport": {
    "width": 1440,
    "height": 900
  },
  "chrome": {
    "trafficLights": true,
    "url": false,
    "titleBarColor": "#0a0a0f",
    "titleBarHeight": 32
  },
  "background": {
    "color": "#0a0a0f",
    "padding": 60,
    "borderRadius": 12
  },
  "cursor": {
    "enabled": true,
    "style": "default",
    "rippleColor": "#9b87ff",
    "transitionMs": 320
  },
  "setup": "{{SETUP}}",
  "steps": [
    {
      "action": "wait",
      "ms": 1400
    },
    {
      "action": "screenshot",
      "name": "01-pipeline-overview"
    },
    {
      "action": "zoom",
      "scale": 1.15,
      "duration": 700
    },
    {
      "action": "wait",
      "ms": 900
    },
    {
      "action": "screenshot",
      "name": "02-pipeline-zoom"
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 500
    },
    {
      "action": "wait",
      "ms": 400
    },
    {
      "action": "click",
      "selector": ".cursor-pointer:has-text('Emma Wilson')",
      "zoom": 1.6
    },
    {
      "action": "wait",
      "ms": 1100
    },
    {
      "action": "screenshot",
      "name": "03-candidate-applied"
    },
    {
      "action": "click",
      "selector": "button:has-text('Advance stage')",
      "zoom": 1.6
    },
    {
      "action": "wait",
      "ms": 1200
    },
    {
      "action": "screenshot",
      "name": "04-emma-advanced"
    },
    {
      "action": "keyboard",
      "key": "Escape"
    },
    {
      "action": "wait",
      "ms": 700
    },
    {
      "action": "click",
      "selector": ".cursor-pointer:has-text('Raj Mehta')",
      "zoom": 1.6
    },
    {
      "action": "wait",
      "ms": 1100
    },
    {
      "action": "screenshot",
      "name": "05-raj-offer"
    },
    {
      "action": "zoom",
      "selector": "button:has-text('Mark hired')",
      "scale": 1.7,
      "duration": 700
    },
    {
      "action": "wait",
      "ms": 600
    },
    {
      "action": "click",
      "selector": "button:has-text('Mark hired')"
    },
    {
      "action": "wait",
      "ms": 2800
    },
    {
      "action": "screenshot",
      "name": "06-hired"
    },
    {
      "action": "zoom",
      "scale": 1,
      "duration": 500
    }
  ],
  "localStorage": {
    "pulse.theme": "employee",
    "pulse.devBanner": "false",
    "pulse.tours.completed": "[\"all\"]",
    "pulse.skipBoot": "1"
  }
}
