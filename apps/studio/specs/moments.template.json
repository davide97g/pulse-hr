{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/moments",
  "viewport": { "width": 1440, "height": 900 },
  "chrome": { "title": "Pulse HR — Moments" },
  "background": { "padding": 48, "borderRadius": 14 },
  "cursor": true,
  "setup": "{{SETUP}}",
  "steps": [
    { "action": "wait", "ms": 1800 },
    { "action": "screenshot", "name": "01-moments-open" },

    { "action": "zoom", "scale": 1.2, "duration": 700 },
    { "action": "wait", "ms": 1600 },
    { "action": "screenshot", "name": "02-first-slide" },
    { "action": "zoom", "scale": 1, "duration": 500 },

    { "action": "click", "selector": "button:has-text('Next')", "zoom": 1.4 },
    { "action": "wait", "ms": 1500 },
    { "action": "screenshot", "name": "03-slide-2" },

    { "action": "click", "selector": "button:has-text('Next')", "zoom": 1.4 },
    { "action": "wait", "ms": 1500 },
    { "action": "screenshot", "name": "04-slide-3" },

    { "action": "click", "selector": "button:has-text('Next')", "zoom": 1.4 },
    { "action": "wait", "ms": 1500 },
    { "action": "screenshot", "name": "05-slide-4" },

    { "action": "click", "selector": "button:has-text('Next')", "zoom": 1.4 },
    { "action": "wait", "ms": 1800 },
    { "action": "screenshot", "name": "06-slide-5" }
  ]
}
