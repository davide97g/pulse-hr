{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/kudos",
  "colorScheme": "dark",
  "viewport": { "width": 1280, "height": 720 },
  "outputSize": { "width": 1920, "height": 1080 },
  "chrome": { "url": true },
  "background": {
    "gradient": { "from": "#667eea", "to": "#764ba2" },
    "borderRadius": 12
  },
  "cursor": true,
  "localStorage": { "pulse.theme": "employee" },
  "setup": {
    "url": "{{BASE_URL}}/login",
    "steps": [
      { "action": "wait", "ms": 200 },
      { "action": "zoom", "selector": "input[type=email]", "scale": 1.8, "duration": 180 },
      { "action": "type", "selector": "input[type=email]", "text": "{{TEST_EMAIL}}", "delay": 12 },
      { "action": "zoom", "selector": "input[type=password]", "scale": 1.8, "duration": 180 },
      {
        "action": "type",
        "selector": "input[type=password]",
        "text": "{{TEST_PASSWORD}}",
        "delay": 12
      },
      { "action": "zoom", "selector": "button[type=submit]", "scale": 1.8, "duration": 180 },
      { "action": "click", "selector": "button[type=submit]" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 2000 },
      { "action": "navigate", "url": "{{BASE_URL}}/dev/recording-reset" },
      { "action": "wait", "ms": 600 },
      {
        "action": "wait",
        "ms": 400,
        "waitFor": "button:has-text('Admin')",
        "timeout": 25000
      },

      { "action": "zoom", "selector": "button:has-text('Admin')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Admin')" },
      { "action": "wait", "ms": 150 },
      { "action": "zoom", "selector": "button:has-text('Continue')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Continue')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 200 },

      {
        "action": "zoom",
        "selector": "button:has-text('Hire faster')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Hire faster')" },
      { "action": "wait", "ms": 120 },
      {
        "action": "zoom",
        "selector": "button:has-text('Retain top talent')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Retain top talent')" },
      { "action": "wait", "ms": 120 },
      {
        "action": "zoom",
        "selector": "button:has-text('Boost engagement')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Boost engagement')" },
      { "action": "wait", "ms": 120 },
      { "action": "zoom", "selector": "button:has-text('Continue')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Continue')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 200 },

      { "action": "zoom", "selector": "#ws-name", "scale": 1.8, "duration": 180 },
      { "action": "fill", "selector": "#ws-name", "text": "" },
      { "action": "type", "selector": "#ws-name", "text": "Bitrock", "delay": 18 },
      { "action": "wait", "ms": 150 },
      { "action": "zoom", "selector": "button:has-text('Continue')", "scale": 2, "duration": 180 },
      { "action": "click", "selector": "button:has-text('Continue')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 200 },

      { "action": "zoom", "selector": "#col-0", "scale": 1.6, "duration": 180 },
      { "action": "type", "selector": "#col-0", "text": "Niccolò Naso", "delay": 14 },
      { "action": "wait", "ms": 80 },
      { "action": "type", "selector": "#col-1", "text": "Yi Zhang", "delay": 14 },
      { "action": "wait", "ms": 80 },
      { "action": "type", "selector": "#col-2", "text": "Andrea Mazza", "delay": 14 },
      { "action": "wait", "ms": 200 },
      {
        "action": "zoom",
        "selector": "button:has-text('Create workspace')",
        "scale": 2,
        "duration": 180
      },
      { "action": "click", "selector": "button:has-text('Create workspace')" },
      { "action": "zoom", "scale": 1, "duration": 80 },
      { "action": "wait", "ms": 1600 },
      { "action": "wait", "ms": 400, "waitFor": "main", "timeout": 10000 }
    ]
  },
  "steps": [
    { "action": "wait", "ms": 400, "waitFor": "text=Send kudos", "timeout": 10000 },
    { "action": "screenshot", "name": "01-kudos-idle", "pauseAfter": 80 },

    { "action": "zoom", "selector": "button[role='combobox']", "scale": 1.9, "duration": 130 },
    {
      "action": "click",
      "selector": "button[role='combobox']",
      "timeout": 8000,
      "pauseAfter": 120
    },
    { "action": "wait", "ms": 180 },
    {
      "action": "zoom",
      "selector": "[role='option']:has-text('Marcus Rivera')",
      "scale": 1.9,
      "duration": 130,
      "timeout": 12000
    },
    {
      "action": "click",
      "selector": "[role='option']:has-text('Marcus Rivera')",
      "timeout": 8000,
      "pauseAfter": 120
    },
    { "action": "wait", "ms": 220 },

    { "action": "zoom", "selector": "textarea[maxlength='200']", "scale": 1.7, "duration": 130 },
    {
      "action": "type",
      "selector": "textarea[maxlength='200']",
      "text": "Thanks for helping unblock payroll reporting before deadline.",
      "delay": 16
    },
    { "action": "wait", "ms": 200 },
    { "action": "screenshot", "name": "02-kudos-composed", "pauseAfter": 80 },

    {
      "action": "zoom",
      "selector": "button:has-text('Send 25 coins')",
      "scale": 2,
      "duration": 130
    },
    {
      "action": "click",
      "selector": "button:has-text('Send 25 coins')",
      "timeout": 8000,
      "pauseAfter": 120
    },
    { "action": "wait", "ms": 1200 },
    { "action": "screenshot", "name": "03-kudos-sent", "pauseAfter": 80 },
    {
      "action": "wait",
      "ms": 200,
      "waitFor": "text=Thanks for helping unblock payroll reporting before deadline.",
      "timeout": 10000
    },
    { "action": "screenshot", "name": "04-feed-updated", "pauseAfter": 80 },
    { "action": "zoom", "scale": 1, "duration": 100 }
  ]
}
