{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/login",
  "colorScheme": "dark",
  "viewport": { "width": 1280, "height": 720 },
  "outputSize": { "width": 1920, "height": 1080 },
  "chrome": { "url": true },
  "background": {
    "gradient": { "from": "#667eea", "to": "#764ba2" },
    "borderRadius": 12
  },
  "cursor": true,
  "localStorage": { "pulse.theme": "employee" },
  "steps": [
    { "action": "wait", "ms": 200 },
    { "action": "zoom", "selector": "input[type=email]", "scale": 1.8, "duration": 180 },
    { "action": "type", "selector": "input[type=email]", "text": "{{TEST_EMAIL}}", "delay": 12 },
    { "action": "zoom", "selector": "input[type=password]", "scale": 1.8, "duration": 180 },
    { "action": "type", "selector": "input[type=password]", "text": "{{TEST_PASSWORD}}", "delay": 12 },
    { "action": "zoom", "scale": 1, "duration": 120 },
    { "action": "click", "selector": "button[type=submit]", "zoom": 2.2 },
    { "action": "wait", "ms": 1600 },

    { "action": "click", "selector": "button:has-text('Admin')", "zoom": 2 },
    { "action": "wait", "ms": 200 },
    { "action": "click", "selector": "button:has-text('Continue')", "zoom": 2.1 },
    { "action": "wait", "ms": 300 },

    { "action": "click", "selector": "button:has-text('Hire faster')", "zoom": 1.9 },
    { "action": "wait", "ms": 120 },
    { "action": "click", "selector": "button:has-text('Retain top talent')", "zoom": 1.9 },
    { "action": "wait", "ms": 120 },
    { "action": "click", "selector": "button:has-text('Boost engagement')", "zoom": 1.9 },
    { "action": "wait", "ms": 180 },
    { "action": "click", "selector": "button:has-text('Continue')", "zoom": 2.1 },
    { "action": "wait", "ms": 300 },

    { "action": "zoom", "selector": "#ws-name", "scale": 1.8, "duration": 180 },
    { "action": "fill", "selector": "#ws-name", "text": "" },
    { "action": "type", "selector": "#ws-name", "text": "Bitrock", "delay": 18 },
    { "action": "zoom", "scale": 1, "duration": 120 },
    { "action": "click", "selector": "button:has-text('Continue')", "zoom": 2.1 },
    { "action": "wait", "ms": 300 },

    { "action": "zoom", "selector": "#col-0", "scale": 1.6, "duration": 180 },
    { "action": "type", "selector": "#col-0", "text": "Niccolò Naso", "delay": 14 },
    { "action": "wait", "ms": 100 },
    { "action": "type", "selector": "#col-1", "text": "Yi Zhang", "delay": 14 },
    { "action": "wait", "ms": 100 },
    { "action": "type", "selector": "#col-2", "text": "Andrea Mazza", "delay": 14 },
    { "action": "zoom", "scale": 1, "duration": 120 },
    { "action": "click", "selector": "button:has-text('Create workspace')", "zoom": 2.2 },
    { "action": "wait", "ms": 1200 },

    { "action": "navigate", "url": "{{BASE_URL}}/focus" },
    { "action": "wait", "ms": 600 },
    { "action": "screenshot", "name": "01-focus-idle" },

    { "action": "click", "selector": "button:has-text('Deep work')", "zoom": 1.7 },
    { "action": "wait", "ms": 300 },
    { "action": "screenshot", "name": "02-preset-deepwork" },

    { "action": "zoom", "selector": "text=Auto-decline meetings", "scale": 1.5, "duration": 300 },
    { "action": "wait", "ms": 200 },
    { "action": "screenshot", "name": "03-automations" },
    { "action": "zoom", "scale": 1, "duration": 220 },
    { "action": "wait", "ms": 150 },

    { "action": "click", "selector": "button:has-text('Start focusing')", "zoom": 1.8 },
    { "action": "wait", "ms": 800 },
    { "action": "screenshot", "name": "04-in-flow" },

    { "action": "zoom", "selector": "[class*='font-mono'][class*='text-'][class*='9xl'], div:has-text('49:') , main", "scale": 1.3, "duration": 400 },
    { "action": "wait", "ms": 900 },
    { "action": "screenshot", "name": "05-timer-glow" },
    { "action": "zoom", "scale": 1, "duration": 300 }
  ]
}
