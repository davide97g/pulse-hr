{
  "url": "{{BASE_URL}}/login",
  "steps": [
    { "action": "wait", "ms": 600 },
    { "action": "fill", "selector": "input[type=email]", "text": "{{TEST_EMAIL}}" },
    { "action": "fill", "selector": "input[type=password]", "text": "{{TEST_PASSWORD}}" },
    { "action": "click", "selector": "button[type=submit]" },
    { "action": "wait", "ms": 3500 },
    { "action": "fill", "selector": "#workspace-name", "text": "Acme" },
    { "action": "click", "selector": "button:has-text('Create my workspace')" },
    { "action": "wait", "ms": 2500 }
  ]
}
