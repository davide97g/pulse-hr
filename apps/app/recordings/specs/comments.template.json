{
  "$schema": "../node_modules/testreel/recording-definition.schema.json",
  "url": "{{BASE_URL}}/login",
  "viewport": { "width": 1440, "height": 900 },
  "colorScheme": "dark",
  "chrome": { "title": "Pulse HR — Comments" },
  "background": { "padding": 48, "borderRadius": 14, "color": "#0a0a0f" },
  "cursor": true,
  "localStorage": { "pulse.theme": "employee" },
  "steps": [
    { "action": "wait", "ms": 500 },
    { "action": "zoom", "selector": "input[type=email]", "scale": 1.8, "duration": 300 },
    { "action": "type", "selector": "input[type=email]", "text": "{{TEST_EMAIL}}", "delay": 22 },
    { "action": "zoom", "selector": "input[type=password]", "scale": 1.8, "duration": 300 },
    { "action": "type", "selector": "input[type=password]", "text": "{{TEST_PASSWORD}}", "delay": 22 },
    { "action": "zoom", "scale": 1, "duration": 200 },
    { "action": "click", "selector": "button[type=submit]", "zoom": 2.2 },
    { "action": "wait", "ms": 3200 },

    { "action": "click", "selector": "button:has-text('Admin')", "zoom": 2 },
    { "action": "wait", "ms": 500 },
    { "action": "click", "selector": "button:has-text('Continue')", "zoom": 2.1 },
    { "action": "wait", "ms": 700 },

    { "action": "click", "selector": "button:has-text('Hire faster')", "zoom": 1.9 },
    { "action": "wait", "ms": 250 },
    { "action": "click", "selector": "button:has-text('Retain top talent')", "zoom": 1.9 },
    { "action": "wait", "ms": 250 },
    { "action": "click", "selector": "button:has-text('Boost engagement')", "zoom": 1.9 },
    { "action": "wait", "ms": 400 },
    { "action": "click", "selector": "button:has-text('Continue')", "zoom": 2.1 },
    { "action": "wait", "ms": 700 },

    { "action": "zoom", "selector": "#ws-name", "scale": 1.8, "duration": 300 },
    { "action": "fill", "selector": "#ws-name", "text": "" },
    { "action": "type", "selector": "#ws-name", "text": "Acme", "delay": 32 },
    { "action": "zoom", "scale": 1, "duration": 200 },
    { "action": "click", "selector": "button:has-text('Continue')", "zoom": 2.1 },
    { "action": "wait", "ms": 700 },

    { "action": "zoom", "selector": "#col-0", "scale": 1.6, "duration": 300 },
    { "action": "type", "selector": "#col-0", "text": "Niccolò Naso", "delay": 25 },
    { "action": "wait", "ms": 200 },
    { "action": "type", "selector": "#col-1", "text": "Yi Zhang", "delay": 25 },
    { "action": "wait", "ms": 200 },
    { "action": "type", "selector": "#col-2", "text": "Andrea Mazza", "delay": 25 },
    { "action": "zoom", "scale": 1, "duration": 200 },
    { "action": "click", "selector": "button:has-text('Create workspace')", "zoom": 2.2 },
    { "action": "wait", "ms": 2200 },
    { "action": "screenshot", "name": "01-dashboard" },

    { "action": "click", "selector": "button[aria-label='Leave a comment']", "zoom": 2 },
    { "action": "wait", "ms": 500 },
    { "action": "click", "selector": ".font-display" },
    { "action": "wait", "ms": 700 },
    { "action": "zoom", "selector": "input[placeholder='Leave a comment…']", "scale": 1.8, "duration": 350 },
    { "action": "type", "selector": "input[placeholder='Leave a comment…']", "text": "greater welcome", "delay": 28 },
    { "action": "wait", "ms": 400 },
    { "action": "click", "selector": "button[aria-label='Post comment']", "zoom": 2 },
    { "action": "wait", "ms": 1200 },
    { "action": "zoom", "scale": 1, "duration": 300 },
    { "action": "screenshot", "name": "02-pin-dropped" },

    { "action": "click", "selector": "button[aria-label^='Open comment']", "zoom": 2.1 },
    { "action": "wait", "ms": 900 },
    { "action": "screenshot", "name": "03-thread-open" },
    { "action": "zoom", "selector": "textarea[placeholder='Reply…']", "scale": 1.7, "duration": 350 },
    { "action": "type", "selector": "textarea[placeholder='Reply…']", "text": "we should make it large with colorful gradient animation ✨", "delay": 26 },
    { "action": "wait", "ms": 500 },
    { "action": "zoom", "scale": 1, "duration": 250 },
    { "action": "click", "selector": "button[aria-label='Send reply']", "zoom": 2.1 },
    { "action": "wait", "ms": 1400 },
    { "action": "screenshot", "name": "04-reply-sent" },
    { "action": "click", "selector": "button[aria-label='Close thread']", "zoom": 1.8 },
    { "action": "wait", "ms": 700 },

    { "action": "navigate", "url": "{{BASE_URL}}/people" },
    { "action": "wait", "ms": 1400 },
    { "action": "screenshot", "name": "05-people" },

    { "action": "click", "selector": "button[aria-label='Leave a comment']", "zoom": 2 },
    { "action": "wait", "ms": 500 },
    { "action": "click", "selector": ":text('Marcus Rivera')" },
    { "action": "wait", "ms": 700 },
    { "action": "zoom", "selector": "input[placeholder='Leave a comment…']", "scale": 1.8, "duration": 350 },
    { "action": "type", "selector": "input[placeholder='Leave a comment…']", "text": "Birthday UI is super cool!", "delay": 26 },
    { "action": "wait", "ms": 400 },
    { "action": "zoom", "scale": 1, "duration": 250 },
    { "action": "click", "selector": "button[aria-label='Post comment']", "zoom": 2.1 },
    { "action": "wait", "ms": 1400 },
    { "action": "screenshot", "name": "06-marcus-comment" },

    { "action": "navigate", "url": "{{BASE_URL}}/feedback" },
    { "action": "wait", "ms": 1600 },
    { "action": "screenshot", "name": "07-feedback" },

    { "action": "click", "selector": ":nth-match(button[aria-label='Upvote'], 1)", "zoom": 2.1 },
    { "action": "wait", "ms": 900 },
    { "action": "screenshot", "name": "08-upvoted" },

    { "action": "click", "selector": ":nth-match(button:has-text('Thread'), 1)", "zoom": 2 },
    { "action": "wait", "ms": 1500 },
    { "action": "screenshot", "name": "09-thread-sidebar" },

    { "action": "zoom", "selector": "[role=dialog] input[placeholder='Reply…']", "scale": 1.7, "duration": 350 },
    { "action": "type", "selector": "[role=dialog] input[placeholder='Reply…']", "text": "love this, let's ship it", "delay": 26 },
    { "action": "wait", "ms": 400 },
    { "action": "zoom", "scale": 1, "duration": 250 },
    { "action": "click", "selector": "[role=dialog] button[aria-label='Send reply']", "zoom": 2.1 },
    { "action": "wait", "ms": 1400 },
    { "action": "screenshot", "name": "10-feedback-reply" },

    { "action": "keyboard", "key": "Escape" },
    { "action": "wait", "ms": 1000 },
    { "action": "screenshot", "name": "11-closed" }
  ]
}
