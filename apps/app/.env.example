VITE_CLERK_PUBLISHABLE_KEY=
DATABASE_URL=
# Required for /api/* on Vercel (serverless). Not exposed to the browser.
CLERK_SECRET_KEY=
FEEDBACK_ADMIN_EMAILS=
# Optional: isolates sidebar-feature rows in Neon (default: "default")
VITE_WORKSPACE_KEY=
# Resend transactional email (free tier: 100/day). See https://resend.com/
RESEND_API_KEY=
# Sender. Dev uses the Resend sandbox; prod needs a verified domain.
EMAIL_FROM="Pulse HR <onboarding@resend.dev>"
# Bearer token validated by /api/cron/* in addition to Vercel's x-vercel-cron header.
CRON_SECRET=
# Absolute URL used in email CTAs (no trailing slash). e.g. https://pulse.example.com
APP_BASE_URL=