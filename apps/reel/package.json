{
  "name": "@pulse-hr/reel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Remotion compositions that render marketing-site video assets (apps/marketing/public/reel/*).",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts DayInPulse ../marketing/public/reel/reel.mp4 --codec=h264 --crf=20",
    "render:webm": "remotion render src/index.ts DayInPulse ../marketing/public/reel/reel.webm --codec=vp8",
    "render:poster": "remotion still src/index.ts DayInPulse ../marketing/public/reel/poster.jpg --frame=0 --image-format=jpeg --jpeg-quality=88",
    "render:all": "bun run render && bun run render:webm && bun run render:poster"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.400",
    "@remotion/cli": "^4.0.400",
    "@remotion/google-fonts": "^4.0.400",
    "@remotion/renderer": "^4.0.400",
    "@pulse-hr/tokens": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.400"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
