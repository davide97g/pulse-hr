{
  "name": "@pulse-hr/tokens",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Shared design tokens (color, font, radius, motion, shadow, themes) consumed by apps/app, apps/feedback, apps/marketing (site + studio content workspace)",
  "exports": {
    ".": "./src/index.ts",
    "./index.css": "./src/index.css",
    "./tokens.css": "./src/tokens.css",
    "./motion.css": "./src/motion.css",
    "./safe-area.css": "./src/safe-area.css",
    "./base.css": "./src/base.css",
    "./wp-aliases.css": "./src/wp-aliases.css",
    "./tailwind": "./src/tailwind.ts"
  },
  "files": [
    "src"
  ],
  "sideEffects": [
    "src/*.css",
    "src/themes/*.css"
  ]
}
