{
  "name": "workflows-people",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.11.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@workflows-people/app' --filter '@pulse-hr/api' --filter '@pulse-hr/feedback' dev",
    "dev:app": "bun run --filter '@workflows-people/app' dev",
    "dev:api": "bun run --filter '@pulse-hr/api' dev",
    "dev:feedback": "bun run --filter '@pulse-hr/feedback' dev",
    "dev:design": "bun run --filter '@pulse-hr/design' dev",
    "dev:marketing": "bun run --filter 'pulse-hr-marketing' dev",
    "build": "bun run --filter '@workflows-people/app' --filter '@pulse-hr/api' --filter '@pulse-hr/feedback' build",
    "build:app": "bun run --filter '@workflows-people/app' build",
    "build:api": "bun run --filter '@pulse-hr/api' build",
    "build:feedback": "bun run --filter '@pulse-hr/feedback' build",
    "build:design": "bun run --filter '@pulse-hr/design' build",
    "build:marketing": "bun run --filter 'pulse-hr-marketing' build",
    "preview": "bun run --filter '@workflows-people/app' preview",
    "preview:feedback": "bun run --filter '@pulse-hr/feedback' preview",
    "preview:design": "bun run --filter '@pulse-hr/design' preview",
    "preview:marketing": "bun run --filter 'pulse-hr-marketing' preview",
    "studio": "bun run --filter '@pulse-hr/studio' studio",
    "render:studio": "bun run --filter '@pulse-hr/studio' render:all",
    "record": "bun run --filter '@pulse-hr/studio' record",
    "lint": "bun run --filter '@workflows-people/app' lint",
    "db:migrate": "bun run --filter '@pulse-hr/api' db:migrate"
  }
}
