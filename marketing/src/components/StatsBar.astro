---
import { STATS } from "../data/landing";
---

<section class="max-w-[1280px] mx-auto px-6 py-20" aria-label="Key stats">
  <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 list-none p-0 m-0">
    {STATS.map((s) => (
      <div class="border-l-2 border-[#b4ff39]/40 pl-5 py-2">
        <dt class="sr-only">{s.l}</dt>
        <dd class="m-0">
          <span class="font-display text-5xl md:text-6xl block">{s.v}</span>
          <span class="text-sm text-white/60 mt-1 block">{s.l}</span>
        </dd>
      </div>
    ))}
  </dl>
</section>
