---
import { CONCEPTS } from "../data/landing";
---

<section id="concepts" class="max-w-[1280px] mx-auto px-6 py-24" aria-labelledby="concepts-title">
  <div class="max-w-2xl">
    <p class="text-xs uppercase tracking-[0.25em] text-[#b4ff39] mb-4">How we think</p>
    <h2 id="concepts-title" class="font-display text-5xl md:text-6xl leading-[1.02] tracking-tight">
      Four concepts that make<br /><em class="italic">this</em> thing different.
    </h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/5 mt-16 border border-white/5 rounded-xl overflow-hidden">
    {CONCEPTS.map((c, i) => (
      <article class="bg-[#0b0b0d] p-10 hover:bg-[#111113] transition-colors group">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-xs text-white/40 tabular-nums">{`0${i + 1}`}</span>
          <span class="h-px flex-1 bg-white/10 group-hover:bg-[#b4ff39]/40 transition-colors"></span>
        </div>
        <h3 class="font-display text-3xl mb-3">{c.k}</h3>
        <p class="text-white/70 leading-relaxed">{c.d}</p>
      </article>
    ))}
  </div>
</section>
